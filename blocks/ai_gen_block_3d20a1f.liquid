{% doc %}
  @prompt
    Create a “Bestsellers” product section for my Shopify store.
    
    Requirements:
    - Add a heading (e.g. “Bestsellers” with a subheading option).
    - Allow me to select a collection (default: Best Sellers collection).
    - Display products in a grid layout (desktop: 4 per row, mobile: 2 per row).
    - Show at least 8 products by default, but allow me to customize the number of products to display.
    - Each product card should include:
      - Product image
      - Product title
      - Price (with compare-at price if available)
      - Optional badge (e.g. “Hot Seller” or “Save ₹X”)
      - Add to Cart button
    
    Customization options:
    - Option to change number of products shown
    - Option to change collection
    - Toggle for showing badges, ratings, and offers
    - Option to edit heading and subheading text
    
    Extra feature:
    - Add a “View All” button below the section that links to the selected collection page.
    
    Design:
    - Clean, modern, minimal UI
    - Rounded product cards with soft shadows
    - Mobile responsive
    
    Goal:
    Make it visually appealing and optimized for conversions.
    
    
    create same as attached  section   , it must be fully dynamic fully mobile responsive , Make the product card more attractive properly showcasing the offers , with more feature like give an option to have both the add to cart and buy now both buttons but user can hide any of these two , there is too much spacing between the title and pricing and then sale price and mrp pirce , make sure to optimize all these , also in the mobile these product card height is kind of two much , make them look beautiful in the mobile also while there must be all these feature, remove these button icons , cart and buy 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bestsellers-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-bestsellers-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-bestsellers-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-bestsellers-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 8px 0;
    font-weight: 700;
  }

  .ai-bestsellers-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-bestsellers-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.view_all_spacing }}px;
  }

  .ai-bestsellers-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: {{ block.settings.card_shadow }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .ai-bestsellers-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
  }

  .ai-bestsellers-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-bestsellers-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-bestsellers-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    right: 12px;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: 12px;
    font-weight: 600;
    z-index: 2;
  }

  .ai-bestsellers-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-bestsellers-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 8px 0;
    font-weight: 600;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-bestsellers-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-bestsellers-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.heading_color }};
  }

  .ai-bestsellers-price-wrapper-{{ ai_gen_id }} {
    margin-bottom: 12px;
  }

  .ai-bestsellers-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 700;
    display: inline-block;
  }

  .ai-bestsellers-compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    margin-left: 8px;
    display: inline-block;
  }

  .ai-bestsellers-savings-{{ ai_gen_id }} {
    display: inline-block;
    margin-left: 8px;
    font-size: 12px;
    color: {{ block.settings.savings_color }};
    font-weight: 600;
  }

  .ai-bestsellers-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    margin-top: auto;
  }

  .ai-bestsellers-btn-{{ ai_gen_id }} {
    flex: 1;
    padding: 12px 16px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-bestsellers-btn-primary-{{ ai_gen_id }} {
    background: {{ block.settings.add_to_cart_bg }};
    color: {{ block.settings.add_to_cart_text_color }};
  }

  .ai-bestsellers-btn-primary-{{ ai_gen_id }}:hover {
    background: {{ block.settings.add_to_cart_hover_bg }};
    transform: translateY(-2px);
  }

  .ai-bestsellers-btn-secondary-{{ ai_gen_id }} {
    background: {{ block.settings.buy_now_bg }};
    color: {{ block.settings.buy_now_text_color }};
  }

  .ai-bestsellers-btn-secondary-{{ ai_gen_id }}:hover {
    background: {{ block.settings.buy_now_hover_bg }};
    transform: translateY(-2px);
  }

  .ai-bestsellers-view-all-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-bestsellers-view-all-btn-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background: {{ block.settings.view_all_bg }};
    color: {{ block.settings.view_all_text_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .ai-bestsellers-view-all-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.view_all_hover_bg }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 989px) {
    .ai-bestsellers-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_tablet }}, 1fr);
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .ai-bestsellers-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-bestsellers-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-bestsellers-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 16px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-bestsellers-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-bestsellers-card-{{ ai_gen_id }} {
      border-radius: {{ block.settings.card_border_radius | times: 0.8 }}px;
    }

    .ai-bestsellers-content-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.75 }}px;
    }

    .ai-bestsellers-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.product_title_size | times: 0.85 }}px;
      margin-bottom: 6px;
    }

    .ai-bestsellers-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size | times: 0.9 }}px;
    }

    .ai-bestsellers-compare-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.compare_price_size | times: 0.85 }}px;
    }

    .ai-bestsellers-btn-{{ ai_gen_id }} {
      padding: 10px 12px;
      font-size: 13px;
    }

    .ai-bestsellers-buttons-{{ ai_gen_id }} {
      gap: 6px;
    }

    .ai-bestsellers-badge-{{ ai_gen_id }} {
      top: 8px;
      right: 8px;
      padding: 4px 8px;
      font-size: 11px;
    }
  }
{% endstyle %}

<bestsellers-section-{{ ai_gen_id }} class="ai-bestsellers-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bestsellers-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-bestsellers-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-bestsellers-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-bestsellers-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      <div class="ai-bestsellers-grid-{{ ai_gen_id }}">
        {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
          <div class="ai-bestsellers-card-{{ ai_gen_id }}">
            <div class="ai-bestsellers-image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-bestsellers-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-bestsellers-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if block.settings.show_badges %}
                {% if product.compare_at_price > product.price %}
                  {% assign savings = product.compare_at_price | minus: product.price %}
                  <div class="ai-bestsellers-badge-{{ ai_gen_id }}">
                    {% if block.settings.badge_type == 'percentage' %}
                      {% assign savings_percent = savings | times: 100.0 | divided_by: product.compare_at_price | round %}
                      {{ savings_percent }}% OFF
                    {% else %}
                      Save {{ savings | money }}
                    {% endif %}
                  </div>
                {% elsif product.available == false %}
                  <div class="ai-bestsellers-badge-{{ ai_gen_id }}">Sold Out</div>
                {% elsif block.settings.custom_badge != blank %}
                  <div class="ai-bestsellers-badge-{{ ai_gen_id }}">{{ block.settings.custom_badge }}</div>
                {% endif %}
              {% endif %}
            </div>

            <div class="ai-bestsellers-content-{{ ai_gen_id }}">
              <h3 class="ai-bestsellers-title-{{ ai_gen_id }}">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>

              <div class="ai-bestsellers-price-wrapper-{{ ai_gen_id }}">
                <span class="ai-bestsellers-price-{{ ai_gen_id }}">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="ai-bestsellers-compare-price-{{ ai_gen_id }}">{{ product.compare_at_price | money }}</span>
                  {% if block.settings.show_savings %}
                    {% assign savings = product.compare_at_price | minus: product.price %}
                    <span class="ai-bestsellers-savings-{{ ai_gen_id }}">Save {{ savings | money }}</span>
                  {% endif %}
                {% endif %}
              </div>

              <div class="ai-bestsellers-buttons-{{ ai_gen_id }}">
                {% if block.settings.show_add_to_cart %}
                  {% if product.available %}
                    <button
                      type="button"
                      class="ai-bestsellers-btn-{{ ai_gen_id }} ai-bestsellers-btn-primary-{{ ai_gen_id }}"
                      data-product-id="{{ product.id }}"
                      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                    >
                      {{ block.settings.add_cart_label }}
                    </button>
                  {% else %}
                    <button
                      type="button"
                      class="ai-bestsellers-btn-{{ ai_gen_id }} ai-bestsellers-btn-primary-{{ ai_gen_id }}"
                      disabled
                    >
                      Sold Out
                    </button>
                  {% endif %}
                {% endif %}

                {% if block.settings.show_buy_now and product.available %}
                  <a
                    href="{{ product.url }}"
                    class="ai-bestsellers-btn-{{ ai_gen_id }} ai-bestsellers-btn-secondary-{{ ai_gen_id }}"
                  >
                    {{ block.settings.buy_label }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if block.settings.show_view_all %}
        <div class="ai-bestsellers-view-all-{{ ai_gen_id }}">
          <a href="{{ block.settings.collection.url }}" class="ai-bestsellers-view-all-btn-{{ ai_gen_id }}">
            {{ block.settings.view_label }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <div style="text-align: center; padding: 60px 20px; color: #999;">
        <p>Please select a collection to display products</p>
      </div>
    {% endif %}
  </div>
</bestsellers-section-{{ ai_gen_id }}>

<script>
  (function() {
    class BestsellersSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAddToCart();
      }

      setupAddToCart() {
        const buttons = this.querySelectorAll('.ai-bestsellers-btn-primary-{{ ai_gen_id }}');
        
        buttons.forEach(button => {
          button.addEventListener('click', async (e) => {
            const variantId = button.dataset.variantId;
            
            if (!variantId) return;

            const originalText = button.textContent;
            button.textContent = 'Adding...';
            button.disabled = true;

            try {
              const response = await fetch('/cart/add.js', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                  items: [{
                    id: variantId,
                    quantity: 1
                  }]
                })
              });

              if (response.ok) {
                button.textContent = 'Added!';
                
                setTimeout(() => {
                  button.textContent = originalText;
                  button.disabled = false;
                }, 2000);

                document.dispatchEvent(new CustomEvent('cart:refresh'));
                
                const cartDrawer = document.querySelector('cart-drawer');
                if (cartDrawer) {
                  cartDrawer.open();
                }
              } else {
                throw new Error('Failed to add to cart');
              }
            } catch (error) {
              button.textContent = 'Error';
              setTimeout(() => {
                button.textContent = originalText;
                button.disabled = false;
              }, 2000);
            }
          });
        });
      }
    }

    customElements.define('bestsellers-section-{{ ai_gen_id }}', BestsellersSection{{ ai_gen_id }});
  })();
</script>

