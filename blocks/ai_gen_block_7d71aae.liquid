{% doc %}
  @prompt
    Create a modern “Product Tabs” section for my Shopify store.
    
    Core Functionality:
    - Add multiple tabs (e.g. All, Best Sellers, French, Trending, Everyday)
    - Each tab should allow me to select a different collection
    - Clicking on a tab dynamically updates the products (no page reload)
    - Option to set a default active tab
    
    Product Display:
    - Products should be displayed in a horizontal scrolling slider (carousel)
    - Desktop: show 4–5 products at a time
    - Mobile: show 2 products at a time
    - Smooth scroll with swipe support on mobile
    - Optional navigation arrows on desktop
    
    Product Card Design:
    - Large rounded product image
    - Discount badge (e.g. “-20%”) on top-left
    - Product title (max 2 lines)
    - Price + compare-at price (strikethrough)
    - Optional rating display
    - Clean, minimal UI like modern beauty brands
    - Subtle hover effect (zoom or elevate)
    
    Customization Options:
    - Add/remove tabs dynamically
    - Assign collection per tab
    - Control number of products per tab
    - Toggle:
      - Discount badge
      - Ratings
      - Compare price
    - Customize:
      - Tab style (pill / underline / button)
      - Active tab highlight color
      - Font size & typography
      - Card border radius & shadow
      - Spacing between products
    
    Important:
    - Do NOT include any “View All” button
    - Focus on seamless horizontal browsing experience
    
    Mobile Optimization:
    - Fully responsive
    - Tabs scroll horizontally on mobile
    - Product slider supports touch swipe
    - Smooth snapping effect for products
    
    Design Style:
    - Minimal, premium, clean
    - Rounded cards with soft shadows
    - Focus on product visuals
    
    Goal:
    Create a smooth, high-converting horizontal tabbed product section for easy browsing.
    
    
    the section must be exact same as attached with proper same product cards 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-tabs-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  .ai-product-tabs-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-tabs-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-product-tabs-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 700;
  }

  .ai-product-tabs-nav-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.tab_spacing }}px;
    margin-bottom: {{ block.settings.tabs_bottom_spacing }}px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 10px;
  }

  .ai-product-tabs-nav-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-product-tabs-tab-{{ ai_gen_id }} {
    flex-shrink: 0;
    padding: {{ block.settings.tab_padding_vertical }}px {{ block.settings.tab_padding_horizontal }}px;
    background-color: {{ block.settings.tab_background }};
    color: {{ block.settings.tab_text_color }};
    border: {{ block.settings.tab_border_width }}px solid {{ block.settings.tab_border_color }};
    border-radius: {{ block.settings.tab_border_radius }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: {{ block.settings.tab_font_size }}px;
    font-weight: 500;
    white-space: nowrap;
  }

  .ai-product-tabs-tab-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tab_hover_background }};
    color: {{ block.settings.tab_hover_text_color }};
  }

  .ai-product-tabs-tab-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.tab_active_background }};
    color: {{ block.settings.tab_active_text_color }};
    border-color: {{ block.settings.tab_active_border_color }};
  }

  .ai-product-tabs-content-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-product-tabs-panel-{{ ai_gen_id }} {
    display: none;
  }

  .ai-product-tabs-panel-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-product-tabs-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-product-tabs-slider-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.product_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 10px 0;
  }

  .ai-product-tabs-slider-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-product-tabs-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.products_per_row_desktop | minus: 1 }} * {{ block.settings.product_gap }}px)) / {{ block.settings.products_per_row_desktop }});
    min-width: calc((100% - ({{ block.settings.products_per_row_desktop | minus: 1 }} * {{ block.settings.product_gap }}px)) / {{ block.settings.products_per_row_desktop }});
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
  }

  .ai-product-tabs-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.card_hover_lift }}px);
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical | plus: 4 }}px {{ block.settings.card_shadow_blur | plus: 8 }}px {{ block.settings.card_shadow_color }};
  }

  .ai-product-tabs-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-product-tabs-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-product-tabs-card-{{ ai_gen_id }}:hover .ai-product-tabs-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-product-tabs-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    z-index: 2;
  }

  .ai-product-tabs-info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-product-tabs-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 8px;
    font-weight: 500;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
  }

  .ai-product-tabs-title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-product-tabs-title-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_active_background }};
  }

  .ai-product-tabs-price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .ai-product-tabs-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-product-tabs-compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size | minus: 2 }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    opacity: 0.7;
  }

  .ai-product-tabs-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    color: {{ block.settings.rating_color }};
  }

  .ai-product-tabs-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-product-tabs-star-{{ ai_gen_id }} {
    width: 14px;
    height: 14px;
    fill: {{ block.settings.rating_color }};
  }

  .ai-product-tabs-nav-arrows-{{ ai_gen_id }} {
    display: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    justify-content: space-between;
    pointer-events: none;
    padding: 0 10px;
  }

  .ai-product-tabs-arrow-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: all;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-product-tabs-arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
    transform: scale(1.1);
  }

  .ai-product-tabs-arrow-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-product-tabs-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }

  @media screen and (min-width: 750px) {
    .ai-product-tabs-nav-arrows-{{ ai_gen_id }} {
      display: flex;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-tabs-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.product_gap }}px) / {{ block.settings.products_per_row_mobile }});
      min-width: calc((100% - {{ block.settings.product_gap }}px) / {{ block.settings.products_per_row_mobile }});
    }

    .ai-product-tabs-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-product-tabs-nav-{{ ai_gen_id }} {
      justify-content: flex-start;
    }
  }
{% endstyle %}

<product-tabs-{{ ai_gen_id }} class="ai-product-tabs-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-tabs-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-product-tabs-header-{{ ai_gen_id }}">
        <h2 class="ai-product-tabs-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="ai-product-tabs-nav-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign tab_enabled_key = 'tab_' | append: i | append: '_enabled'
          assign tab_label_key = 'tab_' | append: i | append: '_label'
          assign tab_enabled = block.settings[tab_enabled_key]
          assign tab_label = block.settings[tab_label_key]
        %}
        {% if tab_enabled and tab_label != blank %}
          <button
            class="ai-product-tabs-tab-{{ ai_gen_id }} {% if i == block.settings.default_tab %}active{% endif %}"
            data-tab="{{ i }}"
          >
            {{ tab_label }}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-product-tabs-content-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign tab_enabled_key = 'tab_' | append: i | append: '_enabled'
          assign collection_key = 'tab_' | append: i | append: '_collection'
          assign tab_enabled = block.settings[tab_enabled_key]
          assign collection = block.settings[collection_key]
        %}
        {% if tab_enabled %}
          <div
            class="ai-product-tabs-panel-{{ ai_gen_id }} {% if i == block.settings.default_tab %}active{% endif %}"
            data-panel="{{ i }}"
          >
            {% if collection != blank and collection.products.size > 0 %}
              <div class="ai-product-tabs-slider-wrapper-{{ ai_gen_id }}">
                <div class="ai-product-tabs-slider-{{ ai_gen_id }}" data-slider="{{ i }}">
                  {% for product in collection.products limit: block.settings.products_limit %}
                    <div class="ai-product-tabs-card-{{ ai_gen_id }}">
                      <div class="ai-product-tabs-image-wrapper-{{ ai_gen_id }}">
                        {% if product.featured_image %}
                          <img
                            src="{{ product.featured_image | image_url: width: 600 }}"
                            alt="{{ product.featured_image.alt | escape }}"
                            class="ai-product-tabs-image-{{ ai_gen_id }}"
                            loading="lazy"
                            width="600"
                            height="600"
                          >
                        {% else %}
                          <div class="ai-product-tabs-image-placeholder-{{ ai_gen_id }}">
                            {{ 'product-1' | placeholder_svg_tag }}
                          </div>
                        {% endif %}

                        {% if block.settings.show_discount_badge and product.compare_at_price > product.price %}
                          {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                          <div class="ai-product-tabs-badge-{{ ai_gen_id }}">
                            -{{ discount }}%
                          </div>
                        {% endif %}
                      </div>

                      <div class="ai-product-tabs-info-{{ ai_gen_id }}">
                        <h3 class="ai-product-tabs-title-{{ ai_gen_id }}">
                          <a href="{{ product.url }}" class="ai-product-tabs-title-link-{{ ai_gen_id }}">
                            {{ product.title }}
                          </a>
                        </h3>

                        <div class="ai-product-tabs-price-wrapper-{{ ai_gen_id }}">
                          <span class="ai-product-tabs-price-{{ ai_gen_id }}">
                            {{ product.price | money }}
                          </span>
                          {% if block.settings.show_compare_price and product.compare_at_price > product.price %}
                            <span class="ai-product-tabs-compare-price-{{ ai_gen_id }}">
                              {{ product.compare_at_price | money }}
                            </span>
                          {% endif %}
                        </div>

                        {% if block.settings.show_rating %}
                          <div class="ai-product-tabs-rating-{{ ai_gen_id }}">
                            <div class="ai-product-tabs-stars-{{ ai_gen_id }}">
                              {% for star in (1..5) %}
                                <svg class="ai-product-tabs-star-{{ ai_gen_id }}" viewBox="0 0 24 24">
                                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                </svg>
                              {% endfor %}
                            </div>
                          </div>
                        {% endif %}
                      </div>
                    </div>
                  {% endfor %}
                </div>

                <div class="ai-product-tabs-nav-arrows-{{ ai_gen_id }}">
                  <button class="ai-product-tabs-arrow-{{ ai_gen_id }} ai-product-tabs-prev-{{ ai_gen_id }}" data-direction="prev" data-slider-id="{{ i }}" aria-label="Previous">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                  </button>
                  <button class="ai-product-tabs-arrow-{{ ai_gen_id }} ai-product-tabs-next-{{ ai_gen_id }}" data-direction="next" data-slider-id="{{ i }}" aria-label="Next">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                  </button>
                </div>
              </div>
            {% else %}
              <div class="ai-product-tabs-empty-{{ ai_gen_id }}">
                No products found. Please select a collection for this tab.
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</product-tabs-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductTabs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.tabs = this.querySelectorAll('.ai-product-tabs-tab-{{ ai_gen_id }}');
        this.panels = this.querySelectorAll('.ai-product-tabs-panel-{{ ai_gen_id }}');
        this.sliders = this.querySelectorAll('.ai-product-tabs-slider-{{ ai_gen_id }}');
        this.arrows = this.querySelectorAll('.ai-product-tabs-arrow-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.setupTabs();
        this.setupSliders();
        this.setupArrows();
      }

      setupTabs() {
        this.tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            const tabId = tab.getAttribute('data-tab');
            
            this.tabs.forEach(t => t.classList.remove('active'));
            this.panels.forEach(p => p.classList.remove('active'));
            
            tab.classList.add('active');
            const panel = this.querySelector(`[data-panel="${tabId}"]`);
            if (panel) {
              panel.classList.add('active');
            }
          });
        });
      }

      setupSliders() {
        this.sliders.forEach(slider => {
          let isDown = false;
          let startX;
          let scrollLeft;

          slider.addEventListener('mousedown', (e) => {
            isDown = true;
            slider.style.cursor = 'grabbing';
            startX = e.pageX - slider.offsetLeft;
            scrollLeft = slider.scrollLeft;
          });

          slider.addEventListener('mouseleave', () => {
            isDown = false;
            slider.style.cursor = 'grab';
          });

          slider.addEventListener('mouseup', () => {
            isDown = false;
            slider.style.cursor = 'grab';
          });

          slider.addEventListener('mousemove', (e) => {
            if (!isDown) return;
            e.preventDefault();
            const x = e.pageX - slider.offsetLeft;
            const walk = (x - startX) * 2;
            slider.scrollLeft = scrollLeft - walk;
          });

          let touchStartX = 0;
          let touchScrollLeft = 0;

          slider.addEventListener('touchstart', (e) => {
            touchStartX = e.touches[0].pageX;
            touchScrollLeft = slider.scrollLeft;
          }, { passive: true });

          slider.addEventListener('touchmove', (e) => {
            const touchX = e.touches[0].pageX;
            const walk = (touchStartX - touchX) * 1.5;
            slider.scrollLeft = touchScrollLeft + walk;
          }, { passive: true });
        });
      }

      setupArrows() {
        this.arrows.forEach(arrow => {
          arrow.addEventListener('click', () => {
            const direction = arrow.getAttribute('data-direction');
            const sliderId = arrow.getAttribute('data-slider-id');
            const slider = this.querySelector(`[data-slider="${sliderId}"]`);
            
            if (slider) {
              const scrollAmount = slider.offsetWidth * 0.8;
              if (direction === 'next') {
                slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
              } else {
                slider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
              }
            }
          });
        });
      }
    }

    customElements.define('product-tabs-{{ ai_gen_id }}', ProductTabs{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product tabs",
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "header",
      "content": "Tabs"
    },
    {
      "type": "range",
      "id": "default_tab",
      "label": "Default active tab",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "tab_spacing",
      "label": "Tab spacing",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "tabs_bottom_spacing",
      "label": "Tabs bottom spacing",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "tab_font_size",
      "label": "Tab font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "tab_padding_vertical",
      "label": "Tab padding vertical",
      "min": 8,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "tab_padding_horizontal",
      "label": "Tab padding horizontal",
      "min": 16,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "tab_border_radius",
      "label": "Tab border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "tab_border_width",
      "label": "Tab border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "tab_background",
      "label": "Tab background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tab_text_color",
      "label": "Tab text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "tab_border_color",
      "label": "Tab border color",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "tab_hover_background",
      "label": "Tab hover background",
      "default": "#f5f5f5"
    },
    {
