{% doc %}
  @prompt
    Create a custom Shopify section 
    
    🎯 Section Requirements:
    
    Layout:
    
    Two-column layout (desktop):
    Left side: Features list with icons and text
    Right side: Large image (hand with nails)
    On mobile: Stack vertically (image below or above content)
    🧱 Content Structure:
    
    Top Heading (center aligned):
    
    Text: Why Soul Struck is Your Nail Bff
    Styling:
    “Your Nail Bff” should be highlighted in a different color (accent color)
    
    Left Side (Features Grid):
    
    6 feature items arranged in 2 columns × 3 rows
    
    Each feature includes:
    
    Icon (SVG or image)
    Title (short tagline)
    
    Feature List:
    
    Where Style meets the Soul
    Bold Nails, Bigger Energy
    Comfort with Quality
    Your Nail’s Style Headquarters
    Cruelty-free & Vegan
    Customer Centric
    🎨 Design Style:
    Clean, modern, minimal
    Use brand colors:
    #E06285 (primary)
    #A08CCB (secondary)
    White background
    Gold accents (optional)
    Icons should be:
    Rounded
    Same color as primary
    Text alignment: center for each feature block
    🖼️ Right Side Image:
    Large responsive image
    Slight rounded corners
    Maintain aspect ratio
    Optional subtle hover zoom effect
    📱 Responsiveness:
    Tablet: 2 columns still okay, reduce spacing
    Mobile:
    Single column
    Features become 1 per row or 2 per row
    Image moves below content
    ⚙️ Shopify Schema:
    
    Include:
    
    Section settings:
    Heading text
    Highlight text color
    Image upload
    Blocks:
    Feature item (icon + text editable), instead of image it will be an. video section , on hovering these feature icons will have slight animations and provide option to customize the video section height and width also , make the overall sectino beautiful 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-nail-bff-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-nail-bff-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-nail-bff-heading-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
    font-weight: 700;
  }

  .ai-nail-bff-highlight-{{ ai_gen_id }} {
    color: {{ block.settings.highlight_color }};
  }

  .ai-nail-bff-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.content_gap }}px;
    align-items: center;
  }

  .ai-nail-bff-features-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.feature_gap }}px;
  }

  .ai-nail-bff-feature-{{ ai_gen_id }} {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border-radius: 12px;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  .ai-nail-bff-feature-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    background-color: {{ block.settings.feature_hover_bg }};
  }

  .ai-nail-bff-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    border-radius: 50%;
    background: {{ block.settings.icon_background }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.4s ease, box-shadow 0.4s ease, background 0.4s ease;
    box-shadow: 0 4px 12px rgba(224, 98, 133, 0.2);
  }

  .ai-nail-bff-feature-{{ ai_gen_id }}:hover .ai-nail-bff-icon-wrapper-{{ ai_gen_id }} {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 8px 24px rgba(224, 98, 133, 0.35);
    background: {{ block.settings.icon_hover_background }};
  }

  .ai-nail-bff-icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    color: {{ block.settings.icon_color }};
    transition: color 0.3s ease;
  }

  .ai-nail-bff-feature-{{ ai_gen_id }}:hover .ai-nail-bff-icon-{{ ai_gen_id }} {
    color: {{ block.settings.icon_hover_color }};
  }

  .ai-nail-bff-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_text_size }}px;
    color: {{ block.settings.feature_text_color }};
    margin: 0;
    line-height: 1.4;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .ai-nail-bff-feature-{{ ai_gen_id }}:hover .ai-nail-bff-feature-title-{{ ai_gen_id }} {
    color: {{ block.settings.feature_hover_text_color }};
  }

  .ai-nail-bff-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.video_width }}%;
    max-width: 100%;
    margin: 0 auto;
    overflow: hidden;
    border-radius: {{ block.settings.video_border_radius }}px;
    background-color: #000000;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
  }

  .ai-nail-bff-video-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.video_height }}px;
  }

  .ai-nail-bff-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-nail-bff-video-placeholder-{{ ai_gen_id }} {
    background: linear-gradient(135deg, #f4f4f4 0%, #e8e8e8 100%);
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.video_border_radius }}px;
    position: relative;
  }

  .ai-nail-bff-video-placeholder-{{ ai_gen_id }} svg {
    width: 100px;
    height: 100px;
    opacity: 0.3;
    color: #999;
  }

  .ai-nail-bff-video-placeholder-text-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    color: #666;
    font-size: 14px;
    text-align: center;
    background: rgba(255, 255, 255, 0.9);
    padding: 8px 16px;
    border-radius: 20px;
  }

  @media screen and (max-width: 989px) {
    .ai-nail-bff-content-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    {% if block.settings.mobile_video_position == 'top' %}
      .ai-nail-bff-video-wrapper-{{ ai_gen_id }} {
        order: -1;
      }
    {% endif %}

    .ai-nail-bff-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-nail-bff-video-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-nail-bff-video-container-{{ ai_gen_id }} {
      height: {{ block.settings.video_height | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-nail-bff-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 16px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    {% if block.settings.mobile_columns == '1' %}
      .ai-nail-bff-features-{{ ai_gen_id }} {
        grid-template-columns: 1fr;
        gap: {{ block.settings.feature_gap | times: 0.8 }}px;
      }
    {% endif %}

    .ai-nail-bff-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.6);
      margin-bottom: {{ block.settings.heading_spacing | times: 0.7 }}px;
    }

    .ai-nail-bff-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-nail-bff-icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size | times: 0.8 }}px * 0.5);
      height: calc({{ block.settings.icon_size | times: 0.8 }}px * 0.5);
    }

    .ai-nail-bff-feature-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.feature_text_size | times: 0.9 }}px;
    }

    .ai-nail-bff-video-container-{{ ai_gen_id }} {
      height: {{ block.settings.video_height | times: 0.6 }}px;
    }
  }
{% endstyle %}

<div class="ai-nail-bff-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-nail-bff-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-nail-bff-heading-{{ ai_gen_id }}">
        {{ block.settings.heading_part_1 }}
        {% if block.settings.heading_part_2 != blank %}
          <span class="ai-nail-bff-highlight-{{ ai_gen_id }}">{{ block.settings.heading_part_2 }}</span>
        {% endif %}
      </h2>
    {% endif %}

    <div class="ai-nail-bff-content-{{ ai_gen_id }}">
      <div class="ai-nail-bff-features-{{ ai_gen_id }}">
        <div class="ai-nail-bff-feature-{{ ai_gen_id }}">
          <div class="ai-nail-bff-icon-wrapper-{{ ai_gen_id }}">
            <svg class="ai-nail-bff-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
              <path d="M2 17l10 5 10-5"></path>
              <path d="M2 12l10 5 10-5"></path>
            </svg>
          </div>
          {% if block.settings.feature_1_title != blank %}
            <h3 class="ai-nail-bff-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_1_title }}</h3>
          {% endif %}
        </div>

        <div class="ai-nail-bff-feature-{{ ai_gen_id }}">
          <div class="ai-nail-bff-icon-wrapper-{{ ai_gen_id }}">
            <svg class="ai-nail-bff-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
          </div>
          {% if block.settings.feature_2_title != blank %}
            <h3 class="ai-nail-bff-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_2_title }}</h3>
          {% endif %}
        </div>

        <div class="ai-nail-bff-feature-{{ ai_gen_id }}">
          <div class="ai-nail-bff-icon-wrapper-{{ ai_gen_id }}">
            <svg class="ai-nail-bff-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          </div>
          {% if block.settings.feature_3_title != blank %}
            <h3 class="ai-nail-bff-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_3_title }}</h3>
          {% endif %}
        </div>

        <div class="ai-nail-bff-feature-{{ ai_gen_id }}">
          <div class="ai-nail-bff-icon-wrapper-{{ ai_gen_id }}">
            <svg class="ai-nail-bff-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </div>
          {% if block.settings.feature_4_title != blank %}
            <h3 class="ai-nail-bff-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_4_title }}</h3>
          {% endif %}
        </div>

        <div class="ai-nail-bff-feature-{{ ai_gen_id }}">
          <div class="ai-nail-bff-icon-wrapper-{{ ai_gen_id }}">
            <svg class="ai-nail-bff-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v20M2 12h20"></path>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
          </div>
          {% if block.settings.feature_5_title != blank %}
            <h3 class="ai-nail-bff-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_5_title }}</h3>
          {% endif %}
        </div>

        <div class="ai-nail-bff-feature-{{ ai_gen_id }}">
          <div class="ai-nail-bff-icon-wrapper-{{ ai_gen_id }}">
            <svg class="ai-nail-bff-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
          </div>
          {% if block.settings.feature_6_title != blank %}
            <h3 class="ai-nail-bff-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_6_title }}</h3>
          {% endif %}
        </div>
      </div>

      <div class="ai-nail-bff-video-wrapper-{{ ai_gen_id }}">
        <div class="ai-nail-bff-video-container-{{ ai_gen_id }}">
          {% if block.settings.video %}
            {{
              block.settings.video
              | video_tag:
                autoplay: block.settings.autoplay,
                loop: block.settings.loop,
                muted: block.settings.muted,
                controls: block.settings.show_controls,
                class: 'ai-nail-bff-video-' | append: ai_gen_id
            }}
          {% else %}
            <div class="ai-nail-bff-video-placeholder-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="5 3 19 12 5 21 5 3"></polygon>
              </svg>
              <div class="ai-nail-bff-video-placeholder-text-{{ ai_gen_id }}">
                Add a video to get started
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Nail BFF features",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Full heading text",
      "default": "Why Soul Struck is Your Nail Bff",
      "info": "This is used for accessibility. Split the heading into two parts below for styling."
    },
    {
      "type": "text",
      "id": "heading_part_1",
      "label": "Heading part 1",
      "default": "Why Soul Struck is"
    },
    {
      "type": "text",
      "id": "heading_part_2",
      "label": "Heading part 2 (highlighted)",
      "default": "Your Nail Bff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading bottom spacing",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#E06285"
    },
    {
      "type": "header",
      "content": "Feature 1 - Style"
    },
    {
      "type": "text",
      "id": "feature_1_title",
      "label": "Title",
      "default": "Where Style meets the Soul"
    },
    {
      "type": "header",
      "content": "Feature 2 - Energy"
    },
    {
      "type": "text",
      "id": "feature_2_title",
      "label": "Title",
      "default": "Bold Nails, Bigger Energy"
    },
    {
      "type": "header",
      "content": "Feature 3 - Quality"
    },
    {
      "type": "text",
      "id": "feature_3_title",
      "label": "Title",
      "default": "Comfort with Quality"
    },
    {
      "type": "header",
      "content": "Feature 4 - Headquarters"
    },
    {
      "type": "text",
      "id": "feature_4_title",
      "label": "Title",
      "default": "Your Nail's Style Headquarters"
    },
    {
      "type": "header",
      "content": "Feature 5 - Vegan"
    },
    {
      "type": "text",
      "id": "feature_5_title",
      "label": "Title",
      "default": "Cruelty-free & Vegan"
    },
    {
      "type": "header",
      "content": "Feature 6 - Customer"
    },
    {
      "type": "text",
      "id": "feature_6_title",
      "label": "Title",
      "default": "Customer Centric"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "range",
      "id": "video_width",
      "label": "Video width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "video_height",
      "label": "Video height",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 500
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Mute video",
      "default": true,
      "info": "Video must be muted for autoplay to work"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show video controls",
      "default": false
