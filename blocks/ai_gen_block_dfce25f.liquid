      "default": 68
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background",
      "default": "#E06285"
    },
    {
      "type": "color",
      "id": "icon_hover_background",
      "label": "Icon hover background",
      "default": "#A08CCB"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "icon_hover_color",
      "label": "Icon hover color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "feature_text_size",
      "label": "Feature text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "feature_text_color",
      "label": "Feature text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "feature_hover_text_color",
      "label": "Feature hover text color",
      "default": "#E06285"
    },
    {
      "type": "color",
      "id": "feature_hover_bg",
      "label": "Feature hover background",
      "default": "#FFF5F8"
    },
    {
      "type": "range",
      "id": "feature_gap",
      "label": "Gap between features",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container max width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Gap between features and video",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Mobile settings"
    },
    {
      "type": "select",
      "id": "mobile_video_position",
      "label": "Video position on mobile",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "bottom"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    }
  ],
  "presets": [
    {
      "name": "Nail BFF features"
    }
  ]
}
{% endschema %}
