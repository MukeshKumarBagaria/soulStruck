{% doc %}
  @prompt
    Create a modern “Available On” section for my Shopify store to showcase the ecommerce platforms where my brand is available.
    
    Layout:
    - Centered section with a heading and optional subheading
    - Below the heading, display platform logos in a horizontal grid
    - Desktop: 3–5 logos per row
    - Mobile: 2 logos per row
    
    Content:
    - Each block should include:
      - Platform logo (e.g. Amazon, Flipkart, Zepto, Blinkit, etc.)
      - Optional platform name
      - Clickable link to the store page on that platform
    
    Design:
    - Each logo inside a rounded card container
    - Soft border or subtle shadow
    - Equal spacing between cards
    - Hover effect:
      - Slight zoom or elevation
      - Optional “Shop Now” overlay
    
    Customization Options:
    - Add/remove platform blocks dynamically
    - Upload custom logos
    - Add custom link for each platform
    - Toggle:
      - Show/hide platform name
      - Enable/disable hover effect
    - Customize:
      - Card border radius
      - Background color
      - Spacing between cards
      - Logo size
      - Section padding
    
    Mobile Optimization:
    - Fully responsive
    - Proper spacing and alignment
    - Touch-friendly clickable cards
    
    Extra Features:
    - Open links in new tab
    - Optional “Trusted Platforms” badge or text
    - Animation on scroll (fade-in or slide-up)
    
    Design Style:
    - Clean, minimal, premium
    - Focus on brand trust and availability
    
    Goal:
    Build trust and increase conversions by showing users that the brand is available on well-known ecommerce platforms.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- liquid
  # Count how many platforms are actually enabled so the grid can center
  # itself when fewer platforms are visible than the desktop column setting.
  assign enabled_count = 0
  for i in (1..6)
    assign key = 'platform_' | append: i | append: '_enabled'
    if block.settings[key]
      assign enabled_count = enabled_count | plus: 1
    endif
  endfor

  assign desktop_cols_setting = block.settings.desktop_columns | times: 1
  if enabled_count > 0 and enabled_count < desktop_cols_setting
    assign effective_cols = enabled_count
    assign constrain_grid_width = true
  else
    assign effective_cols = desktop_cols_setting
    assign constrain_grid_width = false
  endif

  # Cap grid width when fewer cards are visible so they don't stretch huge.
  # Each card targets ~260px wide + the configured gap between them.
  assign card_target_width = 260
  assign cards_total_width = effective_cols | times: card_target_width
  assign gap_count = effective_cols | minus: 1
  assign gaps_total_width = gap_count | times: block.settings.card_spacing
  assign grid_max_width = cards_total_width | plus: gaps_total_width
-%}

{% style %}
  .ai-available-on-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-available-on-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-available-on-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-available-on-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 700;
  }

  .ai-available-on-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    opacity: 0.8;
  }

  {% if block.settings.show_badge %}
    .ai-available-on-badge-{{ ai_gen_id }} {
      display: inline-block;
      padding: 6px 16px;
      background-color: {{ block.settings.badge_background }};
      color: {{ block.settings.badge_text_color }};
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      margin-bottom: 16px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
  {% endif %}

  .ai-available-on-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ effective_cols }}, minmax(0, 1fr));
    gap: {{ block.settings.card_spacing }}px;
    margin-top: {{ block.settings.grid_top_spacing }}px;
    {% if constrain_grid_width %}max-width: {{ grid_max_width }}px;{% else %}max-width: 100%;{% endif %}
    margin-left: auto;
    margin-right: auto;
    justify-content: center;
  }

  .ai-available-on-card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    min-height: {{ block.settings.card_min_height }}px;
    {% if block.settings.card_shadow %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    {% endif %}
  }

  {% if block.settings.enable_hover_effect %}
    .ai-available-on-card-{{ ai_gen_id }}:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
      border-color: {{ block.settings.card_hover_border_color }};
    }

    {% if block.settings.show_overlay %}
      .ai-available-on-overlay-{{ ai_gen_id }} {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: {{ block.settings.overlay_background }};
        border-radius: {{ block.settings.card_border_radius }}px;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
      }

      .ai-available-on-card-{{ ai_gen_id }}:hover .ai-available-on-overlay-{{ ai_gen_id }} {
        opacity: 1;
      }

      .ai-available-on-overlay-text-{{ ai_gen_id }} {
        color: {{ block.settings.overlay_text_color }};
        font-size: 14px;
        font-weight: 600;
      }
    {% endif %}
  {% endif %}

  .ai-available-on-logo-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: {% if block.settings.show_platform_name %}12px{% else %}0{% endif %};
  }

  .ai-available-on-logo-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .ai-available-on-logo-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-available-on-logo-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  {% if block.settings.show_platform_name %}
    .ai-available-on-platform-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.platform_name_size }}px;
      color: {{ block.settings.platform_name_color }};
      font-weight: 600;
      margin: 0;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-available-on-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 16px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-available-on-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.card_spacing | times: 0.8 }}px;
    }

    .ai-available-on-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-available-on-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-available-on-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
      min-height: {{ block.settings.card_min_height | times: 0.8 }}px;
    }

    .ai-available-on-logo-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height | times: 0.8 }}px;
    }
  }

  {% if block.settings.enable_scroll_animation %}
    @keyframes ai-fade-in-up-{{ ai_gen_id }} {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .ai-available-on-card-{{ ai_gen_id }} {
      opacity: 0;
      animation: ai-fade-in-up-{{ ai_gen_id }} 0.6s ease forwards;
    }

    .ai-available-on-card-{{ ai_gen_id }}:nth-child(1) { animation-delay: 0.1s; }
    .ai-available-on-card-{{ ai_gen_id }}:nth-child(2) { animation-delay: 0.2s; }
    .ai-available-on-card-{{ ai_gen_id }}:nth-child(3) { animation-delay: 0.3s; }
    .ai-available-on-card-{{ ai_gen_id }}:nth-child(4) { animation-delay: 0.4s; }
    .ai-available-on-card-{{ ai_gen_id }}:nth-child(5) { animation-delay: 0.5s; }
    .ai-available-on-card-{{ ai_gen_id }}:nth-child(6) { animation-delay: 0.6s; }
  {% endif %}
{% endstyle %}

<available-on-platforms-{{ ai_gen_id }} class="ai-available-on-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-available-on-container-{{ ai_gen_id }}">
    <div class="ai-available-on-header-{{ ai_gen_id }}">
      {% if block.settings.show_badge %}
        <div class="ai-available-on-badge-{{ ai_gen_id }}">
          {{ block.settings.badge_text }}
        </div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-available-on-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <p class="ai-available-on-subheading-{{ ai_gen_id }}">
          {{ block.settings.subheading }}
        </p>
      {% endif %}
    </div>

    <div class="ai-available-on-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign platform_enabled_key = 'platform_' | append: i | append: '_enabled'
          assign platform_logo_key = 'platform_' | append: i | append: '_logo'
          assign platform_name_key = 'platform_' | append: i | append: '_name'
          assign platform_link_key = 'platform_' | append: i | append: '_link'

          assign platform_enabled = block.settings[platform_enabled_key]
          assign platform_logo = block.settings[platform_logo_key]
          assign platform_name = block.settings[platform_name_key]
          assign platform_link = block.settings[platform_link_key]
        %}

        {% if platform_enabled %}
          <a
            href="{{ platform_link }}"
            class="ai-available-on-card-{{ ai_gen_id }}"
            {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
            aria-label="{% if platform_name != blank %}{{ platform_name }}{% else %}Platform {{ i }}{% endif %}"
          >
            <div class="ai-available-on-logo-wrapper-{{ ai_gen_id }}">
              {% if platform_logo %}
                <img
                  src="{{ platform_logo | image_url: width: 400 }}"
                  alt="{{ platform_name | escape }}"
                  class="ai-available-on-logo-{{ ai_gen_id }}"
                  loading="lazy"
                  width="200"
                  height="{{ block.settings.logo_height }}"
                >
              {% else %}
                <div class="ai-available-on-logo-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            {% if block.settings.show_platform_name and platform_name != blank %}
              <p class="ai-available-on-platform-name-{{ ai_gen_id }}">
                {{ platform_name }}
              </p>
            {% endif %}

            {% if block.settings.enable_hover_effect and block.settings.show_overlay %}
              <div class="ai-available-on-overlay-{{ ai_gen_id }}">
                <span class="ai-available-on-overlay-text-{{ ai_gen_id }}">
                  {{ block.settings.overlay_text }}
                </span>
              </div>
            {% endif %}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</available-on-platforms-{{ ai_gen_id }}>

<script>
  (function() {
    class AvailableOnPlatforms{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        {% if block.settings.enable_scroll_animation %}
          this.setupScrollAnimation();
        {% endif %}
      }

      setupScrollAnimation() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.style.animationPlayState = 'running';
              observer.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.1
        });

        const cards = this.querySelectorAll('.ai-available-on-card-{{ ai_gen_id }}');
        cards.forEach(card => {
          card.style.animationPlayState = 'paused';
          observer.observe(card);
        });
      }
    }

    customElements.define('available-on-platforms-{{ ai_gen_id }}', AvailableOnPlatforms{{ ai_gen_id }});
  })();
</script>

