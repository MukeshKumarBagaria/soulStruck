{
  "name": "SoulStruck Custom Header",
  "tag": "div",
  "class": "soulstruck-custom-header-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Logo"
