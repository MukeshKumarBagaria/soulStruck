{% comment %}
  SoulStruck Custom Header — Fully Standalone
  ─ No dependency on any theme header CSS/JS
  ─ Desktop: search pill | centered logo | icons | nav bar below
  ─ Mobile: hamburger | search | logo | icons → drawer for nav
  ─ Sticky at top, bottom shadow appears on scroll
  ─ Smooth animations, fully accessible
{% endcomment %}

{%- liquid
  assign nav_menu   = section.settings.menu
  assign logo_img   = section.settings.logo
  assign logo_text  = section.settings.logo_text | default: shop.name
  assign logo_width = section.settings.logo_width
  assign show_nav   = section.settings.show_nav_bar
  assign show_acc   = section.settings.show_account
  assign show_cart  = section.settings.show_cart
  assign search_ph  = section.settings.search_placeholder
  assign sticky     = section.settings.sticky_header
  assign cart_count = cart.item_count
-%}

<style>
  #ni-ch-{{ section.id }} {
    --ni-ch-bg          : {{ section.settings.bg_color }};
    --ni-ch-fg          : {{ section.settings.text_color }};
    --ni-ch-border      : {{ section.settings.border_color }};
    --ni-ch-nav-color   : {{ section.settings.nav_link_color }};
    --ni-ch-nav-hover   : {{ section.settings.nav_link_hover }};
    --ni-ch-nav-active  : {{ section.settings.nav_active_color }};
    --ni-ch-search-bg   : {{ section.settings.search_bg }};
    --ni-ch-search-bd   : {{ section.settings.search_border_color }};
    --ni-ch-logo-w      : {{ logo_width }}px;
    --ni-ch-shadow      : {{ section.settings.scroll_shadow }};
    --ni-ch-bar-h       : {{ section.settings.bar_height }}px;
    --ni-ch-nav-h       : {{ section.settings.nav_height }}px;
    --ni-ch-drawer-bg   : {{ section.settings.drawer_bg }};
    --ni-ch-drawer-link : {{ section.settings.drawer_link_color }};
    --ni-ch-radius      : {{ section.settings.search_radius }}px;
    --ni-ch-accent      : {{ section.settings.accent_color }};
  }
</style>

{%- comment -%} ── Drawer overlay (rendered before header for stacking) ── {%- endcomment -%}
<div
  class="ni-ch__overlay"
  id="ni-ch-overlay-{{ section.id }}"
  aria-hidden="true"
  tabindex="-1"
></div>

{%- comment -%} ── Mobile drawer ─────────────────────────────────────── {%- endcomment -%}
<aside
  class="ni-ch__drawer"
  id="ni-ch-drawer-{{ section.id }}"
  aria-hidden="true"
  aria-label="{{ section.settings.drawer_label | escape }}"
  role="dialog"
  tabindex="-1"
>
  <div class="ni-ch__drawer-inner">

    <div class="ni-ch__drawer-head">
      {%- if logo_img != blank -%}
        <img
          src="{{ logo_img | image_url: width: 200 }}"
          alt="{{ logo_text | escape }}"
          width="{{ logo_width }}"
          height="{{ logo_width | divided_by: logo_img.aspect_ratio | round }}"
          loading="eager"
          class="ni-ch__drawer-logo"
        >
      {%- else -%}
        <span class="ni-ch__drawer-logo-text">{{ logo_text | escape }}</span>
      {%- endif -%}
      <button
        class="ni-ch__drawer-close"
        aria-label="{{ section.settings.close_label | escape }}"
        id="ni-ch-close-{{ section.id }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <nav class="ni-ch__drawer-nav" aria-label="{{ section.settings.drawer_nav_label | escape }}">
      <ul class="ni-ch__drawer-list" role="list">
        {%- if nav_menu != blank -%}
          {%- for link in nav_menu.links -%}
            <li class="ni-ch__drawer-item">
              <a
                href="{{ link.url }}"
                class="ni-ch__drawer-link{% if link.active %} ni-ch__drawer-link--active{% endif %}"
                {% if link.active %}aria-current="page"{% endif %}
              >
                {{ link.title | escape }}
                {%- if link.links.size > 0 -%}
                  <svg class="ni-ch__drawer-caret" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                {%- endif -%}
              </a>
              {%- if link.links.size > 0 -%}
                <ul class="ni-ch__drawer-sublist" role="list">
                  {%- for sublink in link.links -%}
                    <li>
                      <a href="{{ sublink.url }}" class="ni-ch__drawer-sublink">{{ sublink.title | escape }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>
    </nav>

    <div class="ni-ch__drawer-footer">
      {%- if show_acc -%}
        <a href="{% if customer %}/account{% else %}/account/login{% endif %}" class="ni-ch__drawer-account">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          {% if customer %}{{ customer.first_name | escape }}{% else %}{{ section.settings.account_label | escape }}{% endif %}
        </a>
      {%- endif -%}
      {%- if section.settings.show_social_drawer -%}
        <div class="ni-ch__drawer-social">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</aside>

{%- comment -%} ── Sticky spacer — JS sets height when header goes fixed ── {%- endcomment -%}
<div id="ni-ch-spacer-{{ section.id }}" class="ni-ch__spacer" aria-hidden="true"></div>

{%- comment -%} ── MAIN HEADER ───────────────────────────────────────── {%- endcomment -%}
<div
  id="ni-ch-{{ section.id }}"
  class="ni-ch"
  data-sticky="{{ sticky }}"
  data-section-id="{{ section.id }}"
>
  <header class="ni-ch__header" role="banner">

    {%- comment -%} ── Main bar ──────────────────────────────────────── {%- endcomment -%}
    <div class="ni-ch__bar">

      <!-- LEFT: hamburger (mobile) + search -->
      <div class="ni-ch__left">

        {%- comment -%} Hamburger — mobile only {%- endcomment -%}
        <button
          class="ni-ch__hamburger"
          aria-label="{{ section.settings.menu_label | escape }}"
          aria-expanded="false"
          aria-controls="ni-ch-drawer-{{ section.id }}"
          id="ni-ch-burger-{{ section.id }}"
        >
          <span class="ni-ch__hamburger-line"></span>
          <span class="ni-ch__hamburger-line"></span>
          <span class="ni-ch__hamburger-line"></span>
        </button>

        {%- comment -%} Search pill {%- endcomment -%}
        <form
          action="/search"
          method="get"
          role="search"
          class="ni-ch__search-form"
        >
          <input type="hidden" name="type" value="{{ section.settings.search_type }}">
          <button type="submit" class="ni-ch__search-icon-btn" aria-label="{{ section.settings.search_label | escape }}" tabindex="-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
          <input
            type="search"
            name="q"
            class="ni-ch__search-input"
            placeholder="{{ search_ph | escape }}"
            autocomplete="off"
            autocorrect="off"
            spellcheck="false"
            aria-label="{{ search_ph | escape }}"
          >
        </form>

      </div><!-- /left -->

      <!-- CENTER: Logo -->
      <div class="ni-ch__center">
        <a href="{{ routes.root_url }}" class="ni-ch__logo-link" aria-label="{{ logo_text | escape }}">
          {%- if logo_img != blank -%}
            <img
              src="{{ logo_img | image_url: width: 400 }}"
              srcset="{{ logo_img | image_url: width: 200 }} 200w,
                      {{ logo_img | image_url: width: 400 }} 400w"
              sizes="{{ logo_width }}px"
              alt="{{ logo_text | escape }}"
              width="{{ logo_width }}"
              height="{{ logo_width | divided_by: logo_img.aspect_ratio | round }}"
              loading="eager"
              fetchpriority="high"
              class="ni-ch__logo-img"
            >
          {%- else -%}
            <span class="ni-ch__logo-text">{{ logo_text | escape }}</span>
          {%- endif -%}
        </a>
      </div><!-- /center -->

      <!-- RIGHT: Account + Cart -->
      <div class="ni-ch__right">

        {%- if show_acc and shop.customer_accounts_enabled -%}
          <a
            href="{% if customer %}/account{% else %}/account/login{% endif %}"
            class="ni-ch__icon-btn"
            aria-label="{% if customer %}{{ 'accessibility.account' | t | default: 'My account' }}{% else %}{{ section.settings.account_label | escape }}{% endif %}"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </a>
        {%- endif -%}

        {%- if show_cart -%}
          {%- comment -%}
            Cart icon — always renders the same icon + bubble as the default header.
            The button delegates to the page's existing cart-drawer-component (rendered
            by the default header's header-actions snippet) so there is only ONE drawer
            on the page and it always looks exactly like the native cart drawer.
            cart-icon.js handles count updates and bubble animations automatically.
            cart-drawer.js is loaded as a fallback for standalone use (idempotent).
          {%- endcomment -%}
          <script src="{{ 'cart-icon.js' | asset_url }}" type="module" fetchpriority="low"></script>
          {%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
            <script src="{{ 'cart-drawer.js' | asset_url }}" type="module" fetchpriority="low"></script>
          {%- endif -%}

          <button
            class="ni-ch__icon-btn ni-ch__cart-btn"
            id="ni-ch-cart-{{ section.id }}"
            aria-label="{{ 'accessibility.cart' | t }}"
            aria-describedby="cart-bubble-text"
            aria-haspopup="dialog"
            data-cart-type="{{ settings.cart_type }}"
          >
            <cart-icon
              class="header-actions__cart-icon{% unless cart == empty %} header-actions__cart-icon--has-cart{% endunless %}"
            >
              <span class="svg-wrapper" aria-hidden="true">
                {{- 'icon-cart.svg' | inline_asset_content -}}
              </span>
              {%- render 'cart-bubble', limit: 100, live_region: true -%}
            </cart-icon>
          </button>
        {%- endif -%}

      </div><!-- /right -->

    </div><!-- /bar -->

    {%- comment -%} ── Desktop nav bar ───────────────────────────────── {%- endcomment -%}
    {%- if show_nav and nav_menu != blank -%}
      <nav class="ni-ch__nav" aria-label="{{ section.settings.nav_aria_label | escape }}">
        <ul class="ni-ch__nav-list" role="list">
          {%- for link in nav_menu.links -%}
            <li class="ni-ch__nav-item{% if link.links.size > 0 %} ni-ch__nav-item--has-children{% endif %}">
              <a
                href="{{ link.url }}"
                class="ni-ch__nav-link{% if link.active %} ni-ch__nav-link--active{% endif %}"
                {% if link.active %}aria-current="page"{% endif %}
                {% if link.links.size > 0 %}aria-haspopup="true" aria-expanded="false"{% endif %}
              >
                {{ link.title | escape }}
              </a>
              {%- if link.links.size > 0 -%}
                <ul class="ni-ch__dropdown" role="list">
                  {%- for sublink in link.links -%}
                    <li>
                      <a
                        href="{{ sublink.url }}"
                        class="ni-ch__dropdown-link{% if sublink.active %} ni-ch__dropdown-link--active{% endif %}"
                        {% if sublink.active %}aria-current="page"{% endif %}
                      >{{ sublink.title | escape }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

  </header>
</div><!-- /ni-ch wrapper -->

<style>
/* ═══════════════════════════════════════════════════════════════
   SoulStruck Custom Header
   ═══════════════════════════════════════════════════════════════ */

/* ── Reset scope ──────────────────────────────────────────────── */
.ni-ch *,
.ni-ch *::before,
.ni-ch *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}
.ni-ch a    { text-decoration: none; color: inherit; }
.ni-ch ul   { list-style: none; }
.ni-ch button { background: none; border: none; cursor: pointer; font: inherit; }

/* ── Spacer (prevents layout jump when header becomes fixed) ── */
.ni-ch__spacer {
  display: none;
}

/* ── Wrapper ──────────────────────────────────────────────────── */
.ni-ch {
  background: var(--ni-ch-bg, #fff);
  width: 100%;
  z-index: 9999;
  /* No position here — JS adds ni-ch--fixed when sticky kicks in */
}

/* JS adds this once page scrolls past the header's natural position */
.ni-ch--fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  box-shadow: var(--ni-ch-shadow, 0 2px 12px rgba(0,0,0,0.10));
  animation: ni-ch-slide-in 0.28s cubic-bezier(0.16,1,0.3,1) both;
}
@keyframes ni-ch-slide-in {
  from { transform: translateY(-100%); opacity: 0.6; }
  to   { transform: translateY(0);     opacity: 1; }
}

/* ── Main bar ─────────────────────────────────────────────────── */
.ni-ch__bar {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  height: var(--ni-ch-bar-h, 64px);
  padding: 0 32px;
  border-bottom: 1px solid var(--ni-ch-border, rgba(0,0,0,0.08));
}
@media screen and (max-width: 749px) {
  .ni-ch__bar {
    padding: 0 12px;
    height: var(--ni-ch-bar-h, 56px);
    gap: 8px;
  }
}

/* ── Left column ──────────────────────────────────────────────── */
.ni-ch__left {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}

/* ── Hamburger (mobile only) ──────────────────────────────────── */
.ni-ch__hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 36px;
  height: 36px;
  padding: 6px;
  flex-shrink: 0;
  border-radius: 6px;
  transition: background 0.2s ease;
}
@media (hover: hover) {
  .ni-ch__hamburger:hover { background: rgba(0,0,0,0.05); }
}
@media screen and (max-width: 749px) {
  .ni-ch__hamburger {
    display: flex;
  }
}
.ni-ch__hamburger-line {
  display: block;
  width: 100%;
  height: 1.5px;
  background: var(--ni-ch-fg, #1a1a1a);
  border-radius: 2px;
  transform-origin: center;
  transition: transform 0.3s cubic-bezier(0.16,1,0.3,1),
              opacity 0.25s ease;
}
/* Open state — animated to X */
.ni-ch__hamburger--open .ni-ch__hamburger-line:nth-child(1) {
  transform: translateY(6.5px) rotate(45deg);
}
.ni-ch__hamburger--open .ni-ch__hamburger-line:nth-child(2) {
  opacity: 0;
  transform: scaleX(0);
}
.ni-ch__hamburger--open .ni-ch__hamburger-line:nth-child(3) {
  transform: translateY(-6.5px) rotate(-45deg);
}

/* ── Search form ──────────────────────────────────────────────── */
.ni-ch__search-form {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--ni-ch-search-bg, #fff);
  border: 1px solid var(--ni-ch-search-bd, #e0e0e0);
  border-radius: var(--ni-ch-radius, 8px);
  padding: 0 14px;
  height: 40px;
  max-width: 360px;
  width: 100%;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
.ni-ch__search-form:focus-within {
  border-color: var(--ni-ch-fg, #1a1a1a);
  box-shadow: 0 0 0 1px var(--ni-ch-fg, #1a1a1a);
}
.ni-ch__search-icon-btn {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  color: #9e9e9e;
  padding: 0;
  transition: color 0.2s ease;
}
.ni-ch__search-form:focus-within .ni-ch__search-icon-btn { color: var(--ni-ch-fg, #1a1a1a); }
.ni-ch__search-input {
  flex: 1;
  border: none;
  outline: none;
  background: transparent;
  font-size: 0.875rem;
  color: var(--ni-ch-fg, #1a1a1a);
  min-width: 0;
  line-height: 1;
  /* Remove browser's native search clear button */
  -webkit-appearance: none;
}
.ni-ch__search-input::placeholder { color: #9e9e9e; }
.ni-ch__search-input::-webkit-search-decoration,
.ni-ch__search-input::-webkit-search-cancel-button { display: none; }

/* Mobile: compress search to icon-only */
@media screen and (max-width: 749px) {
  .ni-ch__search-form {
    max-width: unset;
    width: 36px;
    height: 36px;
    padding: 0;
    justify-content: center;
    border-radius: 50%;
    flex-shrink: 0;
    overflow: hidden;
    transition: width 0.35s cubic-bezier(0.16,1,0.3,1),
                border-radius 0.35s ease,
                border-color 0.2s ease;
  }
  .ni-ch__search-form.ni-ch__search-form--expanded {
    width: 180px;
    border-radius: 8px;
    padding: 0 10px;
  }
  .ni-ch__search-input {
    display: none;
    font-size: 0.82rem;
  }
  .ni-ch__search-form--expanded .ni-ch__search-input {
    display: block;
  }
  .ni-ch__search-icon-btn { color: var(--ni-ch-fg, #1a1a1a); }
}

/* ── Center: Logo ─────────────────────────────────────────────── */
.ni-ch__center {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 16px;
}
.ni-ch__logo-link {
  display: flex;
  align-items: center;
  text-decoration: none;
  transition: opacity 0.2s ease;
}
@media (hover: hover) {
  .ni-ch__logo-link:hover { opacity: 0.7; }
}
.ni-ch__logo-img {
  display: block;
  max-width: var(--ni-ch-logo-w, 120px);
  height: auto;
  object-fit: contain;
}
.ni-ch__logo-text {
  font-size: clamp(1.1rem, 2.5vw, 1.6rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: var(--ni-ch-fg, #1a1a1a);
  white-space: nowrap;
  line-height: 1;
}

/* ── Right: Icons ─────────────────────────────────────────────── */
.ni-ch__right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 4px;
}
/* cart icon sizing inside our 40px icon button */
.ni-ch__icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  width: 40px;
  height: 40px;
  border-radius: 8px;
  color: var(--ni-ch-fg, #1a1a1a);
  transition: opacity 0.2s ease, background 0.2s ease;
  flex-shrink: 0;
  /* Reset button defaults */
  background: transparent;
  border: none;
  padding: 0;
  cursor: pointer;
  font: inherit;
  text-decoration: none;
}
@media (hover: hover) {
  .ni-ch__icon-btn:hover { opacity: 0.6; }
}
.ni-ch__icon-btn:active { opacity: 0.4; }

/* ── Native cart icon + bubble (mirrors header-actions.liquid) ─── */
.header-actions__cart-icon {
  --cart-bubble-size: 20px;
  --cart-bubble-top: 4.5px;
  --cart-bubble-right: 2.5px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.header-actions__cart-icon .svg-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
}
.header-actions__cart-icon .svg-wrapper svg {
  width: 22px;
  height: 22px;
}
.header-actions__cart-icon .cart-bubble {
  position: absolute;
  width: var(--cart-bubble-size, 20px);
  top: var(--cart-bubble-top);
  right: var(--cart-bubble-right);
}
/* Donut cut-out on icon where bubble sits */
.header-actions__cart-icon.header-actions__cart-icon--has-cart svg {
  mask: radial-gradient(
    calc(var(--cart-bubble-size) + 2px) at calc(100% - var(--cart-bubble-right)) var(--cart-bubble-top),
    transparent 45.45%,
    #fff 45.45%,
    #fff 100%
  );
}
/* Smaller dot when count is empty (99+) */
cart-icon:has(.cart-bubble__text-count:empty) {
  --cart-bubble-size: 10px;
  --cart-bubble-top: 9px;
  --cart-bubble-right: 9px;
}
/* Bubble animation */
.cart-bubble--animating .cart-bubble__background {
  animation: grow var(--animation-speed, 0.3s) var(--animation-easing, ease);
}
.cart-bubble--animating .cart-bubble__text {
  --start-y: -1em;
  --start-opacity: 1;
  transform: translate(0, var(--start-y, -1em));
  opacity: var(--start-opacity, 1);
  animation: move-and-fade var(--animation-speed, 0.3s) var(--animation-easing, ease);
}

/* ── Desktop nav bar ──────────────────────────────────────────── */
.ni-ch__nav {
  display: flex;
  justify-content: center;
  border-top: 1px solid var(--ni-ch-border, rgba(0,0,0,0.08));
}
.ni-ch__nav-list {
  display: flex;
  align-items: center;
  gap: 0;
  height: var(--ni-ch-nav-h, 44px);
}
.ni-ch__nav-item {
  position: relative;
}
.ni-ch__nav-link {
  display: inline-flex;
  align-items: center;
  height: var(--ni-ch-nav-h, 44px);
  padding: 0 22px;
  font-size: 0.875rem;
  font-weight: 700;
  letter-spacing: 0.01em;
  color: var(--ni-ch-nav-color, #1a1a1a);
  white-space: nowrap;
  position: relative;
  transition: color 0.2s ease;
}
/* Animated underline on hover/active */
.ni-ch__nav-link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 22px;
  right: 22px;
  height: 2px;
  background: var(--ni-ch-nav-active, #1a1a1a);
  border-radius: 2px;
  transform: scaleX(0);
  transition: transform 0.25s cubic-bezier(0.16,1,0.3,1);
  transform-origin: center;
}
@media (hover: hover) {
  .ni-ch__nav-link:hover { color: var(--ni-ch-nav-hover, #1a1a1a); }
  .ni-ch__nav-link:hover::after { transform: scaleX(1); }
}
.ni-ch__nav-link--active { color: var(--ni-ch-nav-active, #1a1a1a); }
.ni-ch__nav-link--active::after { transform: scaleX(1); }

/* Desktop dropdown */
.ni-ch__dropdown {
  position: absolute;
  top: calc(100% + 4px);
  left: 0;
  min-width: 180px;
  background: var(--ni-ch-bg, #fff);
  border: 1px solid var(--ni-ch-border, rgba(0,0,0,0.08));
  border-radius: 10px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.10);
  padding: 6px;
  opacity: 0;
  visibility: hidden;
  transform: translateY(8px);
  transition: opacity 0.2s ease,
              visibility 0.2s ease,
              transform 0.25s cubic-bezier(0.16,1,0.3,1);
  z-index: 100;
  pointer-events: none;
}
.ni-ch__nav-item--has-children:hover .ni-ch__dropdown,
.ni-ch__nav-item--has-children:focus-within .ni-ch__dropdown {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
  pointer-events: auto;
}
.ni-ch__dropdown-link {
  display: block;
  padding: 8px 14px;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--ni-ch-nav-color, #1a1a1a);
  border-radius: 6px;
  transition: background 0.15s ease, color 0.15s ease;
}
@media (hover: hover) {
  .ni-ch__dropdown-link:hover {
    background: rgba(0,0,0,0.05);
    color: var(--ni-ch-nav-active, #1a1a1a);
  }
}
.ni-ch__dropdown-link--active { font-weight: 700; }

/* Hide nav on mobile */
@media screen and (max-width: 749px) {
  .ni-ch__nav { display: none; }
}

/* ── Mobile drawer overlay ────────────────────────────────────── */
.ni-ch__overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 10000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.35s ease, visibility 0.35s ease;
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
}
.ni-ch__overlay--open {
  opacity: 1;
  visibility: visible;
}

/* ── Mobile drawer ────────────────────────────────────────────── */
.ni-ch__drawer {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: min(320px, 88vw);
  background: var(--ni-ch-drawer-bg, #fff);
  z-index: 10001;
  transform: translateX(-100%);
  transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 4px 0 24px rgba(0,0,0,0.12);
}
.ni-ch__drawer--open {
  transform: translateX(0);
}
.ni-ch__drawer-inner {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  overscroll-behavior: contain;
}

/* Drawer header */
.ni-ch__drawer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 20px 16px;
  border-bottom: 1px solid rgba(0,0,0,0.07);
  flex-shrink: 0;
}
.ni-ch__drawer-logo { max-width: 100px; height: auto; }
.ni-ch__drawer-logo-text {
  font-size: 1.25rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--ni-ch-drawer-link, #1a1a1a);
}
.ni-ch__drawer-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 8px;
  color: var(--ni-ch-drawer-link, #1a1a1a);
  transition: background 0.2s ease;
  flex-shrink: 0;
}
@media (hover: hover) {
  .ni-ch__drawer-close:hover { background: rgba(0,0,0,0.06); }
}

/* Drawer nav */
.ni-ch__drawer-nav {
  flex: 1;
  padding: 12px 0;
}
.ni-ch__drawer-list { display: flex; flex-direction: column; }
.ni-ch__drawer-item { border-bottom: 1px solid rgba(0,0,0,0.06); }
.ni-ch__drawer-item:last-child { border-bottom: none; }
.ni-ch__drawer-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 15px 20px;
  font-size: 1rem;
  font-weight: 600;
  color: var(--ni-ch-drawer-link, #1a1a1a);
  transition: background 0.15s ease, color 0.15s ease;
}
@media (hover: hover) {
  .ni-ch__drawer-link:hover { background: rgba(0,0,0,0.04); }
}
.ni-ch__drawer-link--active { color: var(--ni-ch-accent, #1a1a1a); }
.ni-ch__drawer-caret {
  transition: transform 0.25s ease;
  flex-shrink: 0;
}
.ni-ch__drawer-sublist {
  padding: 0 20px 8px 36px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.ni-ch__drawer-sublink {
  display: block;
  padding: 8px 0;
  font-size: 0.9rem;
  font-weight: 500;
  color: rgba(26,26,26,0.7);
  transition: color 0.15s ease;
}
@media (hover: hover) {
  .ni-ch__drawer-sublink:hover { color: var(--ni-ch-drawer-link, #1a1a1a); }
}

/* Drawer footer */
.ni-ch__drawer-footer {
  padding: 16px 20px 24px;
  border-top: 1px solid rgba(0,0,0,0.07);
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.ni-ch__drawer-account {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--ni-ch-drawer-link, #1a1a1a);
  transition: opacity 0.2s ease;
}
@media (hover: hover) {
  .ni-ch__drawer-account:hover { opacity: 0.7; }
}
.ni-ch__drawer-social {
  display: flex;
  gap: 12px;
}
.ni-ch__drawer-social a {
  color: var(--ni-ch-drawer-link, #1a1a1a);
  display: flex;
  transition: opacity 0.2s ease;
}
@media (hover: hover) {
  .ni-ch__drawer-social a:hover { opacity: 0.6; }
}

/* ── Reduced motion ───────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .ni-ch__hamburger-line,
  .ni-ch__drawer,
  .ni-ch__overlay,
  .ni-ch__search-form,
  .ni-ch__nav-link::after,
  .ni-ch__dropdown { transition: none !important; animation: none !important; }
}
</style>

<script>
(function () {
  'use strict';

  const SECTION_ID = '{{ section.id }}';
  const wrapper    = document.getElementById('ni-ch-' + SECTION_ID);
  const overlay    = document.getElementById('ni-ch-overlay-' + SECTION_ID);
  const drawer     = document.getElementById('ni-ch-drawer-' + SECTION_ID);
  const burger     = document.getElementById('ni-ch-burger-' + SECTION_ID);
  const closeBtn   = document.getElementById('ni-ch-close-' + SECTION_ID);
  // cart count is managed by cart-icon.js (CartIcon custom element)

  if (!wrapper) return;

  /* ── Sticky / fixed-position logic ────────────────────────── */
  const isSticky = wrapper.dataset.sticky === 'true';
  const spacer   = document.getElementById('ni-ch-spacer-' + SECTION_ID);
  let   isFixed  = false;
  let   rafId    = null;

  // Record the natural top position of the header (relative to document)
  // Recalculated on resize in case things above it change size.
  let headerNaturalTop = 0;
  function measureHeaderTop() {
    if (isFixed) {
      // While fixed, spacer is in the natural position — use it
      headerNaturalTop = spacer
        ? spacer.getBoundingClientRect().top + window.scrollY
        : 0;
    } else {
      headerNaturalTop = wrapper.getBoundingClientRect().top + window.scrollY;
    }
  }
  measureHeaderTop();

  function applyFixed() {
    if (isFixed) return;
    isFixed = true;
    const h = wrapper.offsetHeight;
    wrapper.classList.add('ni-ch--fixed');
    if (spacer) {
      spacer.style.display = 'block';
      spacer.style.height  = h + 'px';
    }
  }

  function removeFixed() {
    if (!isFixed) return;
    isFixed = false;
    wrapper.classList.remove('ni-ch--fixed');
    if (spacer) {
      spacer.style.display = 'none';
      spacer.style.height  = '0';
    }
  }

  function onScroll() {
    if (rafId) return;
    rafId = requestAnimationFrame(() => {
      const scrollY = window.scrollY;

      if (isSticky) {
        if (scrollY >= headerNaturalTop) {
          applyFixed();
        } else {
          removeFixed();
        }
      }

      // Shadow also when at non-zero scroll (looks like nailinit reference)
      wrapper.classList.toggle('ni-ch--scrolled', scrollY > 2);

      rafId = null;
    });
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // run once on load to set correct initial state

  /* ── Mobile search expand ──────────────────────────────────── */
  const searchForm = wrapper.querySelector('.ni-ch__search-form');
  const searchInput = wrapper.querySelector('.ni-ch__search-input');
  const searchIconBtn = wrapper.querySelector('.ni-ch__search-icon-btn');

  if (searchIconBtn && searchForm && searchInput) {
    searchIconBtn.addEventListener('click', (e) => {
      if (window.innerWidth <= 749) {
        if (!searchForm.classList.contains('ni-ch__search-form--expanded')) {
          e.preventDefault();
          searchForm.classList.add('ni-ch__search-form--expanded');
          searchInput.focus();
        }
      }
    });
    // Collapse on blur outside
    document.addEventListener('click', (e) => {
      if (window.innerWidth <= 749 && !searchForm.contains(e.target)) {
        searchForm.classList.remove('ni-ch__search-form--expanded');
      }
    });
  }

  /* ── Drawer open / close ───────────────────────────────────── */
  let drawerOpen = false;
  let focusTrap  = [];

  function openDrawer() {
    drawerOpen = true;
    drawer?.classList.add('ni-ch__drawer--open');
    overlay?.classList.add('ni-ch__overlay--open');
    burger?.classList.add('ni-ch__hamburger--open');
    burger?.setAttribute('aria-expanded', 'true');
    drawer?.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
    // Focus first focusable in drawer
    setTimeout(() => {
      focusTrap = Array.from(drawer?.querySelectorAll(
        'a[href], button:not([disabled]), input, [tabindex]:not([tabindex="-1"])'
      ) || []);
      (closeBtn || focusTrap[0])?.focus();
    }, 50);
  }

  function closeDrawer() {
    drawerOpen = false;
    drawer?.classList.remove('ni-ch__drawer--open');
    overlay?.classList.remove('ni-ch__overlay--open');
    burger?.classList.remove('ni-ch__hamburger--open');
    burger?.setAttribute('aria-expanded', 'false');
    drawer?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    burger?.focus();
  }

  burger?.addEventListener('click', () => drawerOpen ? closeDrawer() : openDrawer());
  closeBtn?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);

  // Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawerOpen) closeDrawer();
  });

  // Focus trap inside drawer
  drawer?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || !drawerOpen || focusTrap.length === 0) return;
    const first = focusTrap[0];
    const last  = focusTrap[focusTrap.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last)  { e.preventDefault(); first.focus(); }
    }
  });

  /* ── Cart button: open the page's cart-drawer-component ───────
     The default header already renders a cart-drawer-component.
     We delegate to it so the drawer is identical to the native one.
     If no drawer exists (standalone use), fall back to the cart page. */
  const cartBtn = document.getElementById('ni-ch-cart-' + SECTION_ID);
  if (cartBtn && cartBtn.dataset.cartType === 'drawer') {
    cartBtn.addEventListener('click', function () {
      const open = () => {
        const cd = document.querySelector('cart-drawer-component');
        if (cd && typeof cd.open === 'function') {
          cd.open();
        } else {
          window.location.href = '{{ routes.cart_url }}';
        }
      };
      if (customElements.get('cart-drawer-component')) {
        open();
      } else {
        customElements.whenDefined('cart-drawer-component').then(open);
      }
    });
  }

  /* ── Resize: close drawer + reset search + re-measure ──────── */
  window.addEventListener('resize', () => {
    if (window.innerWidth > 749 && drawerOpen) closeDrawer();
    if (window.innerWidth > 749 && searchForm) {
      searchForm.classList.remove('ni-ch__search-form--expanded');
    }
    // Re-measure header position and update spacer height
    measureHeaderTop();
    if (isFixed && spacer) spacer.style.height = wrapper.offsetHeight + 'px';
    onScroll();
  }, { passive: true });

})();
</script>

