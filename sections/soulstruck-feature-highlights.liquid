{% comment %}
  SoulStruck Feature Highlights
  - Modern icon-with-text row (icon in soft tinted circle, bold heading, body text)
  - Each column = a section block (icon, heading, body, optional link)
  - Fully responsive (configurable columns at desktop/tablet/mobile)
  - Mono SVG icons, no emojis
{% endcomment %}

{%- liquid
  assign sid = section.id
  assign cols_d = section.settings.columns_desktop
  assign cols_t = section.settings.columns_tablet
  assign cols_m = section.settings.columns_mobile
-%}

{% style %}
  .ssfh-{{ sid }} {
    --ssfh-bg: {{ section.settings.bg_color }};
    --ssfh-heading-color: {{ section.settings.heading_color }};
    --ssfh-text-color: {{ section.settings.text_color }};
    --ssfh-muted: {{ section.settings.muted_color }};
    --ssfh-icon-color: {{ section.settings.icon_color }};
    --ssfh-icon-bg: {{ section.settings.icon_bg_color }};
    --ssfh-divider: {{ section.settings.divider_color }};
    --ssfh-icon-size: {{ section.settings.icon_size }}px;
    --ssfh-icon-circle: {{ section.settings.icon_circle_size }}px;
    --ssfh-heading-size: {{ section.settings.heading_size }}px;
    --ssfh-body-size: {{ section.settings.body_size }}px;
    --ssfh-section-heading-size: {{ section.settings.section_heading_size }}px;
    --ssfh-gap: {{ section.settings.column_gap }}px;
    background: var(--ssfh-bg);
    padding: clamp(32px, 6vw, {{ section.settings.padding_top }}px) 0 clamp(32px, 6vw, {{ section.settings.padding_bottom }}px);
    color: var(--ssfh-text-color);
    box-sizing: border-box;
    position: relative;
  }

  .ssfh-{{ sid }} *,
  .ssfh-{{ sid }} *::before,
  .ssfh-{{ sid }} *::after {
    box-sizing: border-box;
  }

  .ssfh-{{ sid }}__container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 16px;
  }

  /* ── Section header ─────────────────────────── */
  .ssfh-{{ sid }}__header {
    text-align: {{ section.settings.text_align }};
    margin-bottom: {{ section.settings.header_spacing }}px;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .ssfh-{{ sid }}__eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ssfh-icon-color);
    margin: 0 0 12px;
    line-height: 1;
  }

  .ssfh-{{ sid }}__heading {
    font-size: clamp(22px, 4.5vw, var(--ssfh-section-heading-size));
    font-weight: 700;
    color: var(--ssfh-heading-color);
    margin: 0 0 8px;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .ssfh-{{ sid }}__subheading {
    font-size: clamp(14px, 2.5vw, 16px);
    color: var(--ssfh-muted);
    margin: 0;
    line-height: 1.55;
  }

  /* ── Grid ────────────────────────────────────── */
  .ssfh-{{ sid }}__grid {
    display: grid;
    grid-template-columns: repeat({{ cols_m }}, minmax(0, 1fr));
    gap: var(--ssfh-gap);
    align-items: stretch;
  }

  /* ── Column / card ───────────────────────────── */
  .ssfh-{{ sid }}__col {
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.text_align == 'center' %}center{% elsif section.settings.text_align == 'right' %}flex-end{% else %}flex-start{% endif %};
    text-align: {{ section.settings.text_align }};
    gap: 14px;
    padding: {% if section.settings.card_style == 'card' %}28px 22px{% else %}8px 4px{% endif %};
    background: {% if section.settings.card_style == 'card' %}{{ section.settings.card_bg }}{% else %}transparent{% endif %};
    border-radius: {% if section.settings.card_style == 'card' %}{{ section.settings.card_radius }}px{% else %}0{% endif %};
    border: {% if section.settings.card_style == 'card' %}1px solid var(--ssfh-divider){% else %}none{% endif %};
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    position: relative;
    text-decoration: none;
    color: inherit;
  }

  .ssfh-{{ sid }}__col[href] {
    cursor: pointer;
  }

  @media (hover: hover) {
    .ssfh-{{ sid }}__col[href]:hover {
      transform: translateY(-3px);
      {% if section.settings.card_style == 'card' %}
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.06);
        border-color: var(--ssfh-icon-color);
      {% endif %}
    }
    .ssfh-{{ sid }}__col[href]:hover .ssfh-{{ sid }}__icon-wrap {
      transform: scale(1.05);
    }
  }

  /* Vertical divider between columns (only when no card style) */
  {% if section.settings.show_divider and section.settings.card_style != 'card' %}
    .ssfh-{{ sid }}__col:not(:last-child)::after {
      content: '';
      position: absolute;
      top: 18%;
      right: calc(var(--ssfh-gap) / -2);
      width: 1px;
      height: 64%;
      background: var(--ssfh-divider);
    }
    @media screen and (max-width: 599px) {
      {% if cols_m == 1 %}
        .ssfh-{{ sid }}__col:not(:last-child)::after { display: none; }
      {% else %}
        .ssfh-{{ sid }}__col:nth-child({{ cols_m }}n)::after { display: none; }
      {% endif %}
    }
  {% endif %}

  /* ── Icon ─────────────────────────────────────── */
  .ssfh-{{ sid }}__icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--ssfh-icon-circle);
    height: var(--ssfh-icon-circle);
    border-radius: {% if section.settings.icon_shape == 'circle' %}50%{% elsif section.settings.icon_shape == 'rounded' %}{{ section.settings.icon_radius }}px{% else %}0{% endif %};
    background: {% if section.settings.icon_bg_style == 'filled' %}var(--ssfh-icon-bg){% elsif section.settings.icon_bg_style == 'outlined' %}transparent{% else %}transparent{% endif %};
    border: {% if section.settings.icon_bg_style == 'outlined' %}1.5px solid var(--ssfh-icon-color){% else %}none{% endif %};
    color: var(--ssfh-icon-color);
    flex-shrink: 0;
    transition: transform 0.3s ease, background 0.3s ease;
    margin-bottom: 4px;
  }

  .ssfh-{{ sid }}__icon-wrap svg {
    width: var(--ssfh-icon-size);
    height: var(--ssfh-icon-size);
    stroke: currentColor;
    fill: none;
    display: block;
  }

  .ssfh-{{ sid }}__icon-img {
    width: var(--ssfh-icon-size);
    height: var(--ssfh-icon-size);
    object-fit: contain;
  }

  /* ── Content ─────────────────────────────────── */
  .ssfh-{{ sid }}__content {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }

  .ssfh-{{ sid }}__heading-col {
    font-size: var(--ssfh-heading-size);
    font-weight: 700;
    color: var(--ssfh-heading-color);
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.005em;
    text-transform: {{ section.settings.heading_transform }};
  }

  .ssfh-{{ sid }}__body {
    font-size: var(--ssfh-body-size);
    line-height: 1.6;
    color: var(--ssfh-text-color);
    margin: 0;
    word-break: break-word;
  }

  .ssfh-{{ sid }}__body p { margin: 0 0 6px; }
  .ssfh-{{ sid }}__body p:last-child { margin-bottom: 0; }
  .ssfh-{{ sid }}__body strong { color: var(--ssfh-heading-color); font-weight: 600; }
  .ssfh-{{ sid }}__body a {
    color: var(--ssfh-icon-color);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: opacity 0.2s ease;
  }
  .ssfh-{{ sid }}__body a:hover { opacity: 0.75; }

  .ssfh-{{ sid }}__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ssfh-icon-color);
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: gap 0.25s ease;
  }

  .ssfh-{{ sid }}__cta svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    fill: none;
    transition: transform 0.25s ease;
  }

  .ssfh-{{ sid }}__col[href]:hover .ssfh-{{ sid }}__cta svg,
  .ssfh-{{ sid }}__cta:hover svg {
    transform: translateX(3px);
  }

  /* ── Tablet ──────────────────────────────────── */
  @media screen and (min-width: 600px) {
    .ssfh-{{ sid }}__container {
      padding: 0 24px;
    }
    .ssfh-{{ sid }}__grid {
      grid-template-columns: repeat({{ cols_t }}, minmax(0, 1fr));
      gap: calc(var(--ssfh-gap) + 4px);
    }
    {% if section.settings.show_divider and section.settings.card_style != 'card' %}
      .ssfh-{{ sid }}__col:not(:last-child)::after { display: block; }
      .ssfh-{{ sid }}__col:nth-child({{ cols_t }}n)::after { display: none; }
    {% endif %}
  }

  /* ── Desktop ─────────────────────────────────── */
  @media screen and (min-width: 990px) {
    .ssfh-{{ sid }}__container {
      padding: 0 32px;
    }
    .ssfh-{{ sid }}__grid {
      grid-template-columns: repeat({{ cols_d }}, minmax(0, 1fr));
      gap: calc(var(--ssfh-gap) + 12px);
    }
    .ssfh-{{ sid }}__col {
      gap: 16px;
      padding: {% if section.settings.card_style == 'card' %}36px 28px{% else %}12px 4px{% endif %};
    }
    {% if section.settings.show_divider and section.settings.card_style != 'card' %}
      .ssfh-{{ sid }}__col:not(:last-child)::after { display: block; }
      .ssfh-{{ sid }}__col:nth-child({{ cols_d }}n)::after { display: none; }
    {% endif %}
  }
{% endstyle %}

<div class="ssfh-{{ sid }} soulstruck-feature-highlights" {{ block.shopify_attributes }}>
  <div class="ssfh-{{ sid }}__container">

    {% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="ssfh-{{ sid }}__header">
        {% if section.settings.eyebrow != blank %}
          <span class="ssfh-{{ sid }}__eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="ssfh-{{ sid }}__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="ssfh-{{ sid }}__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="ssfh-{{ sid }}__grid">
        {% for block in section.blocks %}
          {%- liquid
            assign use_image = false
            if block.settings.icon_image != blank
              assign use_image = true
            endif
            assign has_link = false
            if block.settings.link != blank
              assign has_link = true
            endif
            assign tag = 'div'
            if has_link
              assign tag = 'a'
            endif
          -%}
          <{{ tag }}
            class="ssfh-{{ sid }}__col"
            {% if has_link %}href="{{ block.settings.link }}"{% endif %}
            {{ block.shopify_attributes }}
          >
            <span class="ssfh-{{ sid }}__icon-wrap" aria-hidden="true">
              {% if use_image %}
                <img class="ssfh-{{ sid }}__icon-img" src="{{ block.settings.icon_image | image_url: width: 96 }}" alt="" loading="lazy" width="48" height="48">
              {% else %}
                {%- case block.settings.icon -%}
                  {%- when 'heart' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                  {%- when 'sparkle' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
                  {%- when 'shield' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                  {%- when 'truck' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
                  {%- when 'phone' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  {%- when 'mail' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
                  {%- when 'chat' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h.01"/><path d="M12 10h.01"/><path d="M16 10h.01"/></svg>
                  {%- when 'support' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></svg>
                  {%- when 'users' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                  {%- when 'leaf' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
                  {%- when 'gift' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                  {%- when 'star' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  {%- when 'clock' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {%- when 'globe' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                  {%- when 'check' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                  {%- when 'flower' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M12 2a4 4 0 0 1 0 8 4 4 0 0 1 0-8zM12 14a4 4 0 0 1 0 8 4 4 0 0 1 0-8zM2 12a4 4 0 0 1 8 0 4 4 0 0 1-8 0zM14 12a4 4 0 0 1 8 0 4 4 0 0 1-8 0z"/></svg>
                  {%- when 'pin' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 7-8 12-8 12s-8-5-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {%- when 'recycle' -%}
                    <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 19H4.815a1.83 1.83 0 0 1-1.57-.881 1.785 1.785 0 0 1-.004-1.784L7.196 9.5"/><path d="M11 19h8.203a1.83 1.83 0 0 0 1.556-.89 1.784 1.784 0 0 0 0-1.775l-1.226-2.12"/><path d="m14 16 3 3-3 3"/><path d="M8.293 13.596 7.196 9.5 3.1 10.598"/><path d="m9.344 5.811 1.093-1.892A1.83 1.83 0 0 1 11.985 3a1.784 1.784 0 0 1 1.546.888l3.943 6.843"/><path d="m13.378 9.633 4.096 1.098 1.097-4.096"/></svg>
                  {%- when 'none' -%}
                {%- endcase -%}
              {% endif %}
            </span>

            <div class="ssfh-{{ sid }}__content">
              {% if block.settings.heading != blank %}
                <h3 class="ssfh-{{ sid }}__heading-col">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.body != blank %}
                <div class="ssfh-{{ sid }}__body">{{ block.settings.body }}</div>
              {% endif %}
              {% if has_link and block.settings.cta_label != blank %}
                <span class="ssfh-{{ sid }}__cta">
                  {{ block.settings.cta_label }}
                  <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              {% endif %}
            </div>
          </{{ tag }}>
        {% endfor %}
      </div>
    {% else %}
      <div style="text-align:center;padding:32px 16px;color:var(--ssfh-muted);font-size:14px;">
        Add a Feature column block in the theme editor to populate this section.
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Feature highlights",
  "tag": "section",
  "class": "section-feature-highlights",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Small uppercase label above the heading."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "section_heading_size",
      "label": "Heading size (desktop)",
      "min": 20,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Spacing below header",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Style",
      "options": [
        { "value": "minimal", "label": "Minimal (no card)" },
        { "value": "card",    "label": "Card with border" }
      ],
      "default": "minimal"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns (tablet)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 2,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 8,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width",
      "min": 600,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show vertical divider between columns",
      "default": false
    },
    {
