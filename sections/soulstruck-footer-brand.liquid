{% comment %}
  SoulStruck Footer Brand Section
  ─ Giant oversized brand name, cropped at bottom
  ─ Copyright text bottom-left
  ─ Social icons top-right
  ─ Back-to-top pill button bottom-right
  ─ Fully customisable
{% endcomment %}

{%- liquid
  assign brand_name = section.settings.brand_name | default: shop.name
-%}

<style>
  #ni-fb-{{ section.id }} {
    --ni-fb-bg          : {{ section.settings.bg_color }};
    --ni-fb-text-color  : {{ section.settings.text_color }};
    --ni-fb-brand-color : {{ section.settings.brand_color }};
    --ni-fb-icon-color  : {{ section.settings.icon_color }};
    --ni-fb-btt-bg      : {{ section.settings.btt_bg }};
    --ni-fb-btt-color   : {{ section.settings.btt_color }};
    --ni-fb-pt          : {{ section.settings.padding_top }}px;
    background          : var(--ni-fb-bg);
    padding-top         : var(--ni-fb-pt);
    overflow            : hidden;
    position            : relative;
  }
</style>

<section id="ni-fb-{{ section.id }}" class="ni-fb" aria-label="Footer branding">

  <!-- TOP ROW: copyright left, socials right -->
  <div class="ni-fb__top">
    {%- if section.settings.show_copyright -%}
      <p class="ni-fb__copy">
        &copy; {{ 'now' | date: '%Y' }}
        {%- if section.settings.copyright_text != blank -%}
          {{ ' ' }}{{ section.settings.copyright_text | escape }}
        {%- else -%}
          {{ ' ' }}{{ shop.name }}.
          {%- if section.settings.show_powered_by -%}
            {{ ' ' }}Powered by <a href="https://www.shopify.com" target="_blank" rel="noopener" class="ni-fb__shopify-link">Shopify</a>
          {%- endif -%}
        {%- endif -%}
      </p>
    {%- endif -%}

    <div class="ni-fb__socials">
      {%- if section.settings.social_instagram != blank -%}
        <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" class="ni-fb__social-link" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.social_tiktok != blank -%}
        <a href="{{ section.settings.social_tiktok }}" target="_blank" rel="noopener" class="ni-fb__social-link" aria-label="TikTok">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.96a8.27 8.27 0 0 0 4.84 1.55V7.07a4.85 4.85 0 0 1-1.07-.38z"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.social_facebook != blank -%}
        <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener" class="ni-fb__social-link" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.social_twitter != blank -%}
        <a href="{{ section.settings.social_twitter }}" target="_blank" rel="noopener" class="ni-fb__social-link" aria-label="X / Twitter">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.social_youtube != blank -%}
        <a href="{{ section.settings.social_youtube }}" target="_blank" rel="noopener" class="ni-fb__social-link" aria-label="YouTube">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.4a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.social_pinterest != blank -%}
        <a href="{{ section.settings.social_pinterest }}" target="_blank" rel="noopener" class="ni-fb__social-link" aria-label="Pinterest">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.77 1.22-5.17 1.22-5.17s-.31-.62-.31-1.54c0-1.45.84-2.53 1.88-2.53.89 0 1.32.67 1.32 1.47 0 .89-.57 2.23-.87 3.47-.25 1.04.52 1.88 1.54 1.88 1.85 0 3.27-1.95 3.27-4.76 0-2.49-1.79-4.23-4.34-4.23-2.96 0-4.69 2.22-4.69 4.51 0 .89.34 1.85.77 2.37.08.1.09.19.07.29-.08.32-.25 1.04-.29 1.18-.05.19-.16.23-.37.14-1.39-.65-2.26-2.68-2.26-4.32 0-3.51 2.55-6.74 7.35-6.74 3.86 0 6.86 2.75 6.86 6.42 0 3.83-2.41 6.91-5.76 6.91-1.13 0-2.18-.59-2.54-1.28l-.69 2.58c-.25.96-.93 2.17-1.39 2.9.04.01.08.01.12.01"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>

  <!-- GIANT BRAND NAME -->
  <div class="ni-fb__brand-wrap" aria-hidden="true">
    <span class="ni-fb__brand" id="ni-fb-brand-{{ section.id }}">
      {{- brand_name | escape -}}
    </span>
  </div>

  <!-- BACK TO TOP -->
  {%- if section.settings.show_back_to_top -%}
    <button
      class="ni-fb__btt"
      aria-label="{{ section.settings.btt_label | escape }}"
      id="ni-fb-btt-{{ section.id }}"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>
  {%- endif -%}

</section>

<style>
/* ── SoulStruck Footer Brand ──────────────────────────────────── */
.ni-fb {
  width: 100%;
  position: relative;
  user-select: none;
}

/* Top row */
.ni-fb__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 0 32px 24px;
  position: relative;
  z-index: 2;
}
@media screen and (max-width: 749px) {
  .ni-fb__top { padding: 0 20px 16px; }
}

/* Copyright */
.ni-fb__copy {
  font-size: 0.78rem;
  color: var(--ni-fb-text-color, #1a1a1a);
  margin: 0;
  line-height: 1.5;
}
.ni-fb__shopify-link {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
}

/* Socials */
.ni-fb__socials {
  display: flex;
  align-items: center;
  gap: 14px;
}
.ni-fb__social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ni-fb-icon-color, #1a1a1a);
  text-decoration: none;
  transition: opacity 0.2s ease, transform 0.2s ease;
}
@media (hover: hover) {
  .ni-fb__social-link:hover {
    opacity: 0.6;
    transform: translateY(-2px);
  }
}

/* Giant brand name wrapper — clips top overflow */
.ni-fb__brand-wrap {
  width: 100%;
  overflow: hidden;
  /* Show bottom ~45% of the text only (letters cropped from top) */
  height: 55vw;
  max-height: {{ section.settings.crop_height }}px;
  display: flex;
  align-items: flex-end;
  pointer-events: none;
  position: relative;
}

.ni-fb__brand {
  display: block;
  white-space: nowrap;
  font-size: {{ section.settings.font_size_vw }}vw;
  font-weight: {{ section.settings.font_weight }};
  line-height: 0.85;
  letter-spacing: {{ section.settings.letter_spacing }}em;
  color: var(--ni-fb-brand-color, #1a1a1a);
  font-family: {% if section.settings.font_style == 'serif' %}Georgia, serif{% elsif section.settings.font_style == 'mono' %}monospace{% else %}var(--font-heading--family, sans-serif){% endif %};
  text-transform: {{ section.settings.text_case }};
  /* Shift down so top is cropped */
  transform: translateY({{ section.settings.crop_offset }}%);
  padding-left: 0;
  width: 100%;
  transform-origin: bottom left;
}

/* Back to top */
.ni-fb__btt {
  position: absolute;
  bottom: 24px;
  right: 32px;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border-radius: 100px;
  background: var(--ni-fb-btt-bg, #1a1a1a);
  color: var(--ni-fb-btt-color, #ffffff);
  border: none;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(0,0,0,0.18);
  transition: transform 0.25s cubic-bezier(0.16,1,0.3,1),
              background 0.2s ease,
              box-shadow 0.2s ease;
}
@media (hover: hover) {
  .ni-fb__btt:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.22);
  }
}
.ni-fb__btt:active { transform: translateY(0); }

@media screen and (max-width: 749px) {
  .ni-fb__btt { bottom: 16px; right: 16px; width: 40px; height: 40px; }
  .ni-fb__brand-wrap { height: 42vw; max-height: none; }
}

@media (prefers-reduced-motion: reduce) {
  .ni-fb__social-link,
  .ni-fb__btt { transition: none; }
}
</style>

<script>
(function () {
  const btt = document.getElementById('ni-fb-btt-{{ section.id }}');
  if (btt) {
    btt.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
})();
</script>

{% schema %}
{
  "name": "SoulStruck Footer Brand",
  "tag": "section",
  "class": "soulstruck-footer-brand",
  "blocks": [],
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Brand Name"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "info": "Leave empty to use shop name automatically",
      "default": "SoulStruck"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size_vw",
      "label": "Font size (% of viewport width)",
      "info": "Controls how large the text appears",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "vw",
      "default": 25
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "font_style",
      "label": "Font family",
      "options": [
        { "value": "theme",  "label": "Theme heading font" },
        { "value": "serif",  "label": "Serif (Georgia)" },
        { "value": "mono",   "label": "Monospace" }
      ],
      "default": "theme"
    },
    {
      "type": "select",
      "id": "text_case",
      "label": "Text case",
      "options": [
        { "value": "none",       "label": "As typed" },
        { "value": "lowercase",  "label": "lowercase" },
        { "value": "uppercase",  "label": "UPPERCASE" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": -5,
      "max": 10,
      "step": 1,
      "unit": "em",
      "default": -2
    },
    {
      "type": "header",
      "content": "Crop Effect"
    },
    {
      "type": "range",
      "id": "crop_height",
      "label": "Section height (max, desktop px)",
      "info": "Controls how much of the letters is visible",
      "min": 100,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 280
    },
    {
      "type": "range",
      "id": "crop_offset",
      "label": "Vertical crop offset (%)",
      "info": "Positive = push text down (show bottom). Negative = pull up (show top).",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 20
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "checkbox",
      "id": "show_copyright",
      "label": "Show copyright line",
      "default": true
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Custom copyright text",
      "info": "Leave empty to auto-generate '© year shop. Powered by Shopify'"
    },
    {
      "type": "checkbox",
      "id": "show_powered_by",
      "label": "Show 'Powered by Shopify'",
      "default": true
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "X / Twitter URL"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "Pinterest URL"
    },
    {
      "type": "header",
      "content": "Back to Top"
    },
    {
      "type": "checkbox",
      "id": "show_back_to_top",
      "label": "Show back-to-top button",
      "default": true
    },
    {
      "type": "text",
      "id": "btt_label",
      "label": "Back-to-top aria-label",
      "default": "Back to top"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "brand_color",
      "label": "Brand name colour",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Copyright text colour",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Social icon colour",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "btt_bg",
      "label": "Back-to-top background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "btt_color",
      "label": "Back-to-top icon colour",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "SoulStruck Footer Brand",
      "settings": {
        "brand_name": "SoulStruck",
        "font_size_vw": 25,
        "font_weight": "700",
        "crop_height": 280,
        "crop_offset": 20
      }
    }
  ]
}
{% endschema %}
