{% comment %}
  SoulStruck Footer Info
  - Multi-column "icon + heading + body" info row
  - Each column is a section block (icon, heading, body, custom image)
  - Customizable: columns per row (desktop/tablet/mobile), dividers, colors, sizing
  - Drop into the footer section group from the theme editor
{% endcomment %}

{%- liquid
  assign sid = section.id
  assign cols_d = section.settings.columns_desktop
  assign cols_t = section.settings.columns_tablet
  assign cols_m = section.settings.columns_mobile
-%}

{% style %}
  .ssfi-{{ sid }} {
    --ssfi-bg: {{ section.settings.bg_color }};
    --ssfi-text: {{ section.settings.text_color }};
    --ssfi-heading: {{ section.settings.heading_color }};
    --ssfi-icon: {{ section.settings.icon_color }};
    --ssfi-divider: {{ section.settings.divider_color }};
    --ssfi-icon-size: {{ section.settings.icon_size }}px;
    --ssfi-heading-size: {{ section.settings.heading_size }}px;
    --ssfi-body-size: {{ section.settings.body_size }}px;
    --ssfi-icon-stroke: {{ section.settings.icon_stroke }};
    --ssfi-gap: {{ section.settings.column_gap }}px;
    background: var(--ssfi-bg);
    padding: clamp(20px, 4vw, {{ section.settings.padding_top }}px) 0 clamp(20px, 4vw, {{ section.settings.padding_bottom }}px);
    color: var(--ssfi-text);
    box-sizing: border-box;
  }

  .ssfi-{{ sid }} *,
  .ssfi-{{ sid }} *::before,
  .ssfi-{{ sid }} *::after {
    box-sizing: border-box;
  }

  .ssfi-{{ sid }}__container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .ssfi-{{ sid }}__grid {
    display: grid;
    grid-template-columns: repeat({{ cols_m }}, minmax(0, 1fr));
    gap: var(--ssfi-gap);
    align-items: stretch;
  }

  .ssfi-{{ sid }}__col {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 14px;
    padding: 4px 0;
    text-align: {{ section.settings.text_align }};
    position: relative;
  }

  {% if section.settings.show_divider %}
    .ssfi-{{ sid }}__col:not(:last-child)::after {
      content: '';
      position: absolute;
      top: 50%;
      right: calc(var(--ssfi-gap) / -2);
      transform: translateY(-50%);
      width: 1px;
      height: 70%;
      background: var(--ssfi-divider);
    }

    /* hide divider on the last item of each visual row */
    @media screen and (max-width: 599px) {
      {% if cols_m == 1 %}
        .ssfi-{{ sid }}__col:not(:last-child)::after { display: none; }
      {% else %}
        .ssfi-{{ sid }}__col:nth-child({{ cols_m }}n)::after { display: none; }
      {% endif %}
    }
  {% endif %}

  .ssfi-{{ sid }}__icon {
    flex-shrink: 0;
    width: var(--ssfi-icon-size);
    height: var(--ssfi-icon-size);
    color: var(--ssfi-icon);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ssfi-{{ sid }}__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .ssfi-{{ sid }}__icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .ssfi-{{ sid }}__content {
    min-width: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ssfi-{{ sid }}__heading {
    font-size: var(--ssfi-heading-size);
    font-weight: {{ section.settings.heading_weight }};
    color: var(--ssfi-heading);
    margin: 0;
    line-height: 1.3;
    text-transform: {{ section.settings.heading_transform }};
    letter-spacing: 0.005em;
    word-break: break-word;
  }

  .ssfi-{{ sid }}__body {
    font-size: var(--ssfi-body-size);
    line-height: 1.55;
    color: var(--ssfi-text);
    margin: 0;
    word-break: break-word;
  }

  .ssfi-{{ sid }}__body p { margin: 0 0 6px; }
  .ssfi-{{ sid }}__body p:last-child { margin-bottom: 0; }
  .ssfi-{{ sid }}__body a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ssfi-{{ sid }}__body a:hover {
    color: var(--ssfi-heading);
  }

  /* Tablet */
  @media screen and (min-width: 600px) {
    .ssfi-{{ sid }}__grid {
      grid-template-columns: repeat({{ cols_t }}, minmax(0, 1fr));
      gap: calc(var(--ssfi-gap) + 4px);
    }
    {% if section.settings.show_divider %}
      .ssfi-{{ sid }}__col:not(:last-child)::after { display: block; }
      .ssfi-{{ sid }}__col:nth-child({{ cols_t }}n)::after { display: none; }
    {% endif %}
  }

  /* Desktop */
  @media screen and (min-width: 990px) {
    .ssfi-{{ sid }}__container {
      padding: 0 24px;
    }
    .ssfi-{{ sid }}__grid {
      grid-template-columns: repeat({{ cols_d }}, minmax(0, 1fr));
      gap: calc(var(--ssfi-gap) + 12px);
    }
    .ssfi-{{ sid }}__col {
      gap: 16px;
      padding: 8px 0;
    }
    {% if section.settings.show_divider %}
      .ssfi-{{ sid }}__col:not(:last-child)::after { display: block; }
      .ssfi-{{ sid }}__col:nth-child({{ cols_d }}n)::after { display: none; }
    {% endif %}
  }
{% endstyle %}

<div class="ssfi-{{ sid }} soulstruck-footer-info" {{ block.shopify_attributes }}>
  <div class="ssfi-{{ sid }}__container">
    {% if section.blocks.size > 0 %}
      <div class="ssfi-{{ sid }}__grid">
        {% for block in section.blocks %}
          {%- liquid
            assign use_image = false
            if block.settings.icon_image != blank
              assign use_image = true
            endif
          -%}
          <div class="ssfi-{{ sid }}__col" {{ block.shopify_attributes }}>
            <span class="ssfi-{{ sid }}__icon" aria-hidden="true">
              {% if use_image %}
                <img class="ssfi-{{ sid }}__icon-img" src="{{ block.settings.icon_image | image_url: width: 96 }}" alt="" loading="lazy" width="48" height="48">
              {% else %}
                {%- case block.settings.icon -%}
                  {%- when 'heart' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                  {%- when 'chat' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h.01"/><path d="M12 10h.01"/><path d="M16 10h.01"/></svg>
                  {%- when 'mail' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
                  {%- when 'phone' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  {%- when 'pin' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 7-8 12-8 12s-8-5-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {%- when 'truck' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
                  {%- when 'shield' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                  {%- when 'gift' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                  {%- when 'star' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  {%- when 'sparkle' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
                  {%- when 'leaf' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
                  {%- when 'globe' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                  {%- when 'clock' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {%- when 'instagram' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                  {%- when 'whatsapp' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                  {%- when 'none' -%}
                {%- endcase -%}
              {% endif %}
            </span>
            <div class="ssfi-{{ sid }}__content">
              {% if block.settings.heading != blank %}
                <h3 class="ssfi-{{ sid }}__heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.body != blank %}
                <div class="ssfi-{{ sid }}__body">{{ block.settings.body }}</div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div style="text-align:center;padding:24px;color:var(--ssfi-text);font-size:14px;">
        Add a column block in the theme editor.
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Footer info row",
  "tag": "section",
  "class": "section-footer-info",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns (tablet)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 2,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width",
      "min": 600,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show vertical divider between columns",
      "default": true
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "icon_stroke",
      "label": "Icon stroke width",
      "min": 1,
      "max": 3,
      "step": 0.25,
      "default": 1.5
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading text style",
      "options": [
        { "value": "none", "label": "Normal" },
        { "value": "lowercase", "label": "lowercase" },
        { "value": "uppercase", "label": "UPPERCASE" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#e5e5e5"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Info column",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none",      "label": "— No icon —" },
            { "value": "heart",     "label": "❤️ Heart" },
            { "value": "chat",      "label": "💬 Chat / Message" },
            { "value": "mail",      "label": "✉️ Mail" },
            { "value": "phone",     "label": "📞 Phone" },
            { "value": "pin",       "label": "📍 Location pin" },
            { "value": "truck",     "label": "🚚 Truck / Delivery" },
            { "value": "shield",    "label": "🛡️ Shield / Secure" },
            { "value": "gift",      "label": "🎁 Gift" },
            { "value": "star",      "label": "⭐ Star" },
            { "value": "sparkle",   "label": "✨ Sparkle" },
            { "value": "leaf",      "label": "🌿 Leaf" },
            { "value": "globe",     "label": "🌐 Globe" },
            { "value": "clock",     "label": "🕐 Clock" },
            { "value": "instagram", "label": "📷 Instagram" },
            { "value": "whatsapp",  "label": "💚 WhatsApp" }
          ],
          "default": "heart"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom icon image (overrides dropdown)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Add a short description for this column.</p>"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Footer info row",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "icon": "heart",
            "heading": "1% for women",
            "body": "<p>a percentage of our revenue and profits goes back towards women and children welfare</p>"
          }
        },
        {
          "type": "column",
          "settings": {
            "icon": "chat",
            "heading": "Feedback, Bulk Orders, Franchise Inquiries, PR, or anything else?",
            "body": "<p>support@nailin.it</p>"
          }
        },
        {
          "type": "column",
          "settings": {
            "icon": "phone",
            "heading": "Always here for you!",
            "body": "<p>+91 8591365198</p>"
          }
        },
        {
          "type": "column",
          "settings": {
            "icon": "pin",
            "heading": "Meet Us",
            "body": "<p>nailinit hq, 408, shalimar morya park, andheri (w), mumbai - 400093, mh, in</p><p>gstin: 09aakcd8320r1zx</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
