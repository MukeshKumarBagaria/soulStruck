{% comment %}
  SoulStruck Hero Slider
  Split layout: left (text) | right (image OR video)
  ─ Unlimited slides (up to 20 blocks)
  ─ Right side: image / Shopify video / YouTube / Vimeo
  ─ Per-slide video controls: autoplay, loop, muted, player controls
  ─ Accessible, touch/swipe, keyboard, autoplay pause on hover
{% endcomment %}

{%- assign autoplay_ms  = section.settings.autoplay_speed | times: 1000 -%}
{%- assign slide_count  = section.blocks | size -%}

<style>
  #ni-hero-{{ section.id }} {
    --ni-h-accent : {{ section.settings.accent_color }};
    --ni-h-bg     : {{ section.settings.bg_color }};
    --ni-h-radius : {{ section.settings.card_radius }}px;
    --ni-h-pt     : {{ section.settings.padding_top }}px;
    --ni-h-pb     : {{ section.settings.padding_bottom }}px;
  }
</style>

<section
  id="ni-hero-{{ section.id }}"
  class="ni-hero-slider"
  data-autoplay="{{ section.settings.autoplay }}"
  data-speed="{{ autoplay_ms }}"
>

  <div class="ni-hero__inner">
    {%- for block in section.blocks -%}
      {%- assign is_active = forloop.first -%}

      <div
        class="ni-hero__slide{% if is_active %} ni-hero__slide--active{% endif %}"
        data-slide="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >

        {%- comment -%} ── LEFT: text content ── {%- endcomment -%}
        <div class="ni-hero__left">
          {%- if block.settings.badge_text != blank -%}
            <div class="ni-hero__badge">
              {%- if block.settings.badge_emoji != blank -%}
                <span class="ni-hero__badge-emoji" aria-hidden="true">{{ block.settings.badge_emoji }}</span>
              {%- endif -%}
              <span>{{ block.settings.badge_text | escape }}</span>
            </div>
          {%- endif -%}

          {%- if block.settings.heading != blank -%}
            <h2 class="ni-hero__heading">{{ block.settings.heading }}</h2>
          {%- endif -%}

          {%- if block.settings.subtext != blank -%}
            <p class="ni-hero__subtext">{{ block.settings.subtext | escape }}</p>
          {%- endif -%}

          {%- if block.settings.cta_text != blank -%}
            <a href="{{ block.settings.cta_url | default: '#' }}" class="ni-hero__cta">
              {{ block.settings.cta_text | escape }}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          {%- endif -%}
        </div>

        {%- comment -%} ── RIGHT: media card ── {%- endcomment -%}
        <div class="ni-hero__right">
          <div class="ni-hero__card" style="background-color: {{ block.settings.card_bg_color }};">

            {%- if block.settings.show_blobs -%}
              <span class="ni-hero__blob ni-hero__blob--tl" aria-hidden="true"></span>
              <span class="ni-hero__blob ni-hero__blob--tr" aria-hidden="true"></span>
              <span class="ni-hero__blob ni-hero__blob--bl" aria-hidden="true"></span>
              <span class="ni-hero__blob ni-hero__blob--br" aria-hidden="true"></span>
            {%- endif -%}

            {%- assign media_type = block.settings.media_type | default: 'image' -%}

            {%- if media_type == 'video' -%}

              {%- comment -%} ── Shopify-hosted video ── {%- endcomment -%}
              {%- if block.settings.card_video != blank -%}
                <video
                  class="ni-hero__card-video ni-hero__card-media"
                  {% if block.settings.video_autoplay and is_active %}autoplay{% endif %}
                  {% if block.settings.video_loop %}loop{% endif %}
                  {% if block.settings.video_muted %}muted{% endif %}
                  {% if block.settings.video_controls %}controls{% endif %}
                  playsinline
                  preload="metadata"
                  aria-label="{{ block.settings.heading | escape }}"
                  data-video-autoplay="{{ block.settings.video_autoplay }}"
                >
                  {%- for source in block.settings.card_video.sources -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {%- endfor -%}
                </video>

              {%- comment -%} ── YouTube / Vimeo embed ── {%- endcomment -%}
              {%- elsif block.settings.card_video_url != blank -%}
                {%- assign vtype = block.settings.card_video_url.type -%}
                {%- assign vid   = block.settings.card_video_url.id -%}
                {%- assign v_auto    = block.settings.video_autoplay | default: false -%}
                {%- assign v_loop    = block.settings.video_loop     | default: false -%}
                {%- assign v_muted   = block.settings.video_muted    | default: true  -%}
                {%- assign v_ctrl    = block.settings.video_controls | default: false -%}

                {%- if vtype == 'youtube' -%}
                  {%- capture embed_src -%}https://www.youtube.com/embed/{{ vid }}?enablejsapi=1&rel=0&modestbranding=1&{% if v_auto and is_active %}autoplay=1&{% endif %}{% if v_muted %}mute=1&{% endif %}{% if v_loop %}loop=1&playlist={{ vid }}&{% endif %}controls={% if v_ctrl %}1{% else %}0{% endif %}{%- endcapture -%}
                {%- elsif vtype == 'vimeo' -%}
                  {%- capture embed_src -%}https://player.vimeo.com/video/{{ vid }}?{% if v_auto and is_active %}autoplay=1&{% endif %}{% if v_muted %}muted=1&{% endif %}{% if v_loop %}loop=1&{% endif %}controls={% if v_ctrl %}1{% else %}0{% endif %}&dnt=1{%- endcapture -%}
                {%- endif -%}

                {%- if embed_src != blank -%}
                  <iframe
                    class="ni-hero__card-iframe ni-hero__card-media"
                    src="{{ embed_src }}"
                    frameborder="0"
                    allow="autoplay; fullscreen; picture-in-picture"
                    allowfullscreen
                    title="{{ block.settings.heading | default: 'Slide video' | escape }}"
                    loading="{% if is_active %}eager{% else %}lazy{% endif %}"
                    data-video-type="{{ vtype }}"
                    data-video-autoplay="{{ v_auto }}"
                    data-video-src-base="https://{% if vtype == 'youtube' %}www.youtube.com/embed/{{ vid }}{% elsif vtype == 'vimeo' %}player.vimeo.com/video/{{ vid }}{% endif %}?enablejsapi=1&rel=0&modestbranding=1&mute={% if v_muted %}1{% else %}0{% endif %}&loop={% if v_loop %}1{% else %}0{% endif %}{% if v_loop and vtype == 'youtube' %}&playlist={{ vid }}{% endif %}&controls={% if v_ctrl %}1{% else %}0{% endif %}"
                  ></iframe>
                {%- endif -%}
              {%- endif -%}

            {%- else -%}
              {%- comment -%} ── Image ── {%- endcomment -%}
              {%- if block.settings.card_image != blank -%}
                <img
                  src="{{ block.settings.card_image | image_url: width: 900 }}"
                  srcset="
                    {{ block.settings.card_image | image_url: width: 450 }} 450w,
                    {{ block.settings.card_image | image_url: width: 750 }} 750w,
                    {{ block.settings.card_image | image_url: width: 900 }} 900w,
                    {{ block.settings.card_image | image_url: width: 1200 }} 1200w
                  "
                  sizes="(max-width: 749px) 100vw, 50vw"
                  alt="{{ block.settings.card_image.alt | default: block.settings.heading | escape }}"
                  width="900"
                  height="{{ 900 | divided_by: block.settings.card_image.aspect_ratio | round }}"
                  loading="{% if is_active %}eager{% else %}lazy{% endif %}"
                  class="ni-hero__card-img ni-hero__card-media"
                >
              {%- endif -%}
            {%- endif -%}

            {%- comment -%} ── Pricing overlay ── {%- endcomment -%}
            {%- if block.settings.price_line_1 != blank or block.settings.price_line_2 != blank -%}
              <div class="ni-hero__price-box">
                {%- if block.settings.price_line_1 != blank -%}
                  <p class="ni-hero__price-label">{{ block.settings.price_line_1 | escape }}</p>
                  {%- if block.settings.price_value_1 != blank -%}
                    <p class="ni-hero__price-value">{{ block.settings.price_value_1 | escape }}</p>
                  {%- endif -%}
                {%- endif -%}
                {%- if block.settings.price_line_1 != blank and block.settings.price_line_2 != blank -%}
                  <hr class="ni-hero__price-divider">
                {%- endif -%}
                {%- if block.settings.price_line_2 != blank -%}
                  <p class="ni-hero__price-label">{{ block.settings.price_line_2 | escape }}</p>
                  {%- if block.settings.price_value_2 != blank -%}
                    <p class="ni-hero__price-value">{{ block.settings.price_value_2 | escape }}</p>
                  {%- endif -%}
                {%- endif -%}
              </div>
            {%- endif -%}

          </div>
        </div>

      </div>
    {%- endfor -%}
  </div>

  {%- if slide_count > 1 -%}
    <div class="ni-hero__nav">
      <button class="ni-hero__arrow ni-hero__arrow--prev" aria-label="Previous slide">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <div class="ni-hero__dots" role="tablist" aria-label="Slide navigation">
        {%- for block in section.blocks -%}
          <button
            class="ni-hero__dot{% if forloop.first %} ni-hero__dot--active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-label="Slide {{ forloop.index }}"
            data-index="{{ forloop.index0 }}"
          ></button>
        {%- endfor -%}
      </div>

      <button class="ni-hero__arrow ni-hero__arrow--next" aria-label="Next slide">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  {%- endif -%}

</section>

<style>
/* ═══════════════════════════════════════════════════════
   SoulStruck Hero Slider
   ═══════════════════════════════════════════════════════ */
#ni-hero-{{ section.id }} {
  background: var(--ni-h-bg);
  padding: var(--ni-h-pt) 0 var(--ni-h-pb);
  position: relative;
  overflow: hidden;
}

#ni-hero-{{ section.id }} .ni-hero__inner {
  position: relative;
  width: 100%;
  min-height: 340px;
}

/* ── Slides ── */
#ni-hero-{{ section.id }} .ni-hero__slide {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1.5fr);
  align-items: center;
  gap: 40px;
  max-width: 1320px;
  margin: 0 auto;
  padding: 0 40px;
  position: absolute;
  inset: 0;
  opacity: 0;
  transform: translateX(60px);
  transition: opacity 0.55s cubic-bezier(0.16,1,0.3,1),
              transform 0.55s cubic-bezier(0.16,1,0.3,1);
  pointer-events: none;
}
#ni-hero-{{ section.id }} .ni-hero__slide--active {
  opacity: 1;
  transform: translateX(0);
  pointer-events: auto;
  position: relative;
}
#ni-hero-{{ section.id }} .ni-hero__slide--exit {
  opacity: 0;
  transform: translateX(-60px);
  position: absolute;
  pointer-events: none;
}

/* ── Left ── */
#ni-hero-{{ section.id }} .ni-hero__left {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 20px;
}
#ni-hero-{{ section.id }} .ni-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8rem;
  font-weight: 500;
  color: #555;
  letter-spacing: 0.01em;
}
#ni-hero-{{ section.id }} .ni-hero__badge-emoji { font-size: 1rem; }
#ni-hero-{{ section.id }} .ni-hero__heading {
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 900;
  line-height: 1.08;
  letter-spacing: -0.02em;
  color: #1a1a1a;
  margin: 0;
  white-space: pre-line;
}
#ni-hero-{{ section.id }} .ni-hero__subtext {
  font-size: 0.95rem;
  color: #555;
  margin: 0;
  max-width: 320px;
  line-height: 1.6;
}
#ni-hero-{{ section.id }} .ni-hero__cta {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #1a1a1a;
  color: #fff;
  font-size: 0.9rem;
  font-weight: 600;
  padding: 13px 24px;
  border-radius: 100px;
  text-decoration: none;
  letter-spacing: 0.01em;
  transition: background 0.2s ease, transform 0.2s ease;
}
#ni-hero-{{ section.id }} .ni-hero__cta:hover {
  background: #333;
  transform: translateY(-1px);
}
#ni-hero-{{ section.id }} .ni-hero__cta svg { transition: transform 0.2s ease; }
#ni-hero-{{ section.id }} .ni-hero__cta:hover svg { transform: translateX(3px); }

/* ── Right card ── */
#ni-hero-{{ section.id }} .ni-hero__right { display: flex; align-items: stretch; }
#ni-hero-{{ section.id }} .ni-hero__card {
  position: relative;
  border-radius: var(--ni-h-radius);
  overflow: hidden;
  width: 100%;
  aspect-ratio: 1 / 0.72;
  display: flex;
  align-items: flex-end;
}

/* Shared media styles — image, video, iframe */
#ni-hero-{{ section.id }} .ni-hero__card-media {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}
#ni-hero-{{ section.id }} .ni-hero__card-img {
  object-fit: cover;
  object-position: center top;
}
#ni-hero-{{ section.id }} .ni-hero__card-video {
  object-fit: cover;
  background: #000;
}
#ni-hero-{{ section.id }} .ni-hero__card-iframe {
  border: none;
  pointer-events: auto;
}

/* ── Blob decorations ── */
#ni-hero-{{ section.id }} .ni-hero__blob {
  position: absolute;
  width: 90px;
  height: 70px;
  background: rgba(255,255,255,0.55);
  border-radius: 50% 40% 55% 45%;
  z-index: 1;
  pointer-events: none;
}
#ni-hero-{{ section.id }} .ni-hero__blob--tl { top: -20px;  left: 10px;  }
#ni-hero-{{ section.id }} .ni-hero__blob--tr { top: -15px;  right: 40px; width: 70px; height: 55px; }
#ni-hero-{{ section.id }} .ni-hero__blob--bl { bottom: -15px; left: 40px; width: 70px; height: 55px; }
#ni-hero-{{ section.id }} .ni-hero__blob--br { bottom: -20px; right: 10px; }

/* ── Price overlay ── */
#ni-hero-{{ section.id }} .ni-hero__price-box {
  position: absolute;
  right: 28px;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  text-align: center;
  color: #fff;
  pointer-events: none;
}
#ni-hero-{{ section.id }} .ni-hero__price-label {
  font-size: clamp(1rem, 2.2vw, 1.5rem);
  font-weight: 500;
  margin: 0 0 2px;
  opacity: 0.9;
}
#ni-hero-{{ section.id }} .ni-hero__price-value {
  font-size: clamp(1.6rem, 3.5vw, 2.8rem);
  font-weight: 900;
  letter-spacing: -0.02em;
  margin: 0 0 6px;
  line-height: 1;
}
#ni-hero-{{ section.id }} .ni-hero__price-divider {
  border: none;
  border-top: 1px solid rgba(255,255,255,0.5);
  margin: 8px 0;
}

/* ── Navigation ── */
#ni-hero-{{ section.id }} .ni-hero__nav {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 24px 48px 0;
  max-width: 1200px;
  margin: 0 auto;
}
#ni-hero-{{ section.id }} .ni-hero__arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1.5px solid rgba(0,0,0,0.18);
  background: transparent;
  cursor: pointer;
  color: #1a1a1a;
  transition: border-color 0.2s ease, background 0.2s ease;
  flex-shrink: 0;
}
#ni-hero-{{ section.id }} .ni-hero__arrow:hover {
  border-color: #1a1a1a;
  background: rgba(0,0,0,0.05);
}
#ni-hero-{{ section.id }} .ni-hero__dots { display: flex; gap: 6px; align-items: center; }
#ni-hero-{{ section.id }} .ni-hero__dot {
  height: 8px;
  width: 8px;
  border-radius: 100px;
  background: rgba(0,0,0,0.2);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: width 0.35s cubic-bezier(0.16,1,0.3,1), background 0.25s ease;
}
#ni-hero-{{ section.id }} .ni-hero__dot--active {
  width: 28px;
  background: #1a1a1a;
}

/* ── Mobile ── */
@media (max-width: 749px) {
  #ni-hero-{{ section.id }} .ni-hero__slide {
    grid-template-columns: 1fr;
    padding: 0 20px;
    gap: 20px;
  }
  /* Media on top, text below */
  #ni-hero-{{ section.id }} .ni-hero__right { order: 1; }
  #ni-hero-{{ section.id }} .ni-hero__left  { order: 2; align-items: flex-start; }
  #ni-hero-{{ section.id }} .ni-hero__inner  { min-height: auto; }
  #ni-hero-{{ section.id }} .ni-hero__heading { font-size: 2rem; }
  #ni-hero-{{ section.id }} .ni-hero__card   { aspect-ratio: 1 / 0.9; }
  #ni-hero-{{ section.id }} .ni-hero__price-box { right: 16px; }
  #ni-hero-{{ section.id }} .ni-hero__nav    { padding: 16px 20px 0; }
  #ni-hero-{{ section.id }} .ni-hero__left   { gap: 12px; }
}

@media (prefers-reduced-motion: reduce) {
  #ni-hero-{{ section.id }} .ni-hero__slide { transition: none; }
  #ni-hero-{{ section.id }} .ni-hero__dot   { transition: none; }
}
</style>

<script>
(function () {
  'use strict';

  const section  = document.getElementById('ni-hero-{{ section.id }}');
  if (!section) return;

  const slides   = Array.from(section.querySelectorAll('.ni-hero__slide'));
  const dots     = Array.from(section.querySelectorAll('.ni-hero__dot'));
  const prevBtn  = section.querySelector('.ni-hero__arrow--prev');
  const nextBtn  = section.querySelector('.ni-hero__arrow--next');
  const doAuto   = section.dataset.autoplay === 'true';
  const speed    = parseInt(section.dataset.speed) || 5000;

  if (slides.length < 2) {
    // Single slide — still handle video autoplay
    const v = slides[0]?.querySelector('.ni-hero__card-video');
    if (v && v.dataset.videoAutoplay === 'true') v.play().catch(() => {});
    return;
  }

  let current = 0;
  let timer   = null;

  /* ── Video helpers ── */
  function pauseSlideMedia(slide) {
    // Native video
    slide.querySelectorAll('.ni-hero__card-video').forEach(v => v.pause());

    // YouTube / Vimeo iframe — swap src to version without autoplay
    slide.querySelectorAll('.ni-hero__card-iframe').forEach(iframe => {
      const base = iframe.dataset.videoSrcBase;
      if (base) iframe.src = base; // reset to non-autoplay src
    });
  }

  function playSlideMedia(slide) {
    // Native video
    slide.querySelectorAll('.ni-hero__card-video').forEach(v => {
      if (v.dataset.videoAutoplay === 'true') v.play().catch(() => {});
    });

    // YouTube / Vimeo iframe — swap src to version with autoplay
    slide.querySelectorAll('.ni-hero__card-iframe').forEach(iframe => {
      const base = iframe.dataset.videoSrcBase;
      const want = iframe.dataset.videoAutoplay === 'true';
      if (base && want) iframe.src = base + '&autoplay=1';
    });
  }

  /* ── Core goTo ── */
  function goTo(index) {
    const prev = current;
    current = (index + slides.length) % slides.length;
    if (prev === current) return;

    // Exit previous
    pauseSlideMedia(slides[prev]);
    slides[prev].classList.add('ni-hero__slide--exit');
    slides[prev].classList.remove('ni-hero__slide--active');
    dots[prev]?.classList.remove('ni-hero__dot--active');
    dots[prev]?.setAttribute('aria-selected', 'false');

    // Enter next
    slides[current].classList.add('ni-hero__slide--active');
    slides[current].classList.remove('ni-hero__slide--exit');
    dots[current]?.classList.add('ni-hero__dot--active');
    dots[current]?.setAttribute('aria-selected', 'true');
    playSlideMedia(slides[current]);

    setTimeout(() => slides[prev].classList.remove('ni-hero__slide--exit'), 650);
  }

  /* ── Autoplay ── */
  function startAutoplay() {
    if (!doAuto) return;
    timer = setInterval(() => goTo(current + 1), speed);
  }
  function stopAutoplay() { clearInterval(timer); timer = null; }

  /* ── Controls ── */
  nextBtn?.addEventListener('click', () => { stopAutoplay(); goTo(current + 1); startAutoplay(); });
  prevBtn?.addEventListener('click', () => { stopAutoplay(); goTo(current - 1); startAutoplay(); });

  dots.forEach(dot => dot.addEventListener('click', e => {
    stopAutoplay();
    goTo(parseInt(e.currentTarget.dataset.index));
    startAutoplay();
  }));

  // Pause autoplay on hover (not when interacting with video)
  section.addEventListener('mouseenter', stopAutoplay);
  section.addEventListener('mouseleave', startAutoplay);

  // Touch swipe
  let touchX = 0;
  section.addEventListener('touchstart', e => { touchX = e.touches[0].clientX; }, { passive: true });
  section.addEventListener('touchend',   e => {
    const d = e.changedTouches[0].clientX - touchX;
    if (Math.abs(d) > 50) { stopAutoplay(); goTo(current + (d < 0 ? 1 : -1)); startAutoplay(); }
  }, { passive: true });

  // Keyboard arrows when focused inside section
  section.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft')  { stopAutoplay(); goTo(current - 1); startAutoplay(); }
    if (e.key === 'ArrowRight') { stopAutoplay(); goTo(current + 1); startAutoplay(); }
  });

  // Init first slide media
  playSlideMedia(slides[0]);
  startAutoplay();
})();
</script>

{% schema %}
{
  "name": "SoulStruck Hero Slider",
  "tag": "section",
  "class": "soulstruck-hero-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "max_blocks": 20,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Left — Text Content"
        },
        {
          "type": "text",
          "id": "badge_emoji",
          "label": "Badge emoji",
          "default": "🎯"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text",
          "default": "limited time offer"
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "more nails,\nmore savings"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "Shop the best deals on press-on nails"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Button text",
          "default": "save now"
        },
        {
          "type": "url",
          "id": "cta_url",
