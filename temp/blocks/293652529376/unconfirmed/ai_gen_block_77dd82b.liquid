{% doc %}
  @prompt
    create this type of exact section with option to add atleast 7 image but can be upto 10 images
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-gallery-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-image-gallery__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-image-gallery__item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-image-gallery__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.aspect_ratio }}%;
  }

  .ai-image-gallery__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  {% if block.settings.enable_hover_zoom %}
    .ai-image-gallery__item-{{ ai_gen_id }}:hover .ai-image-gallery__image-{{ ai_gen_id }} {
      transform: scale(1.05);
    }
  {% endif %}

  .ai-image-gallery__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-image-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-image-gallery__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.gap_mobile }}px;
    }
  }
{% endstyle %}

<image-gallery-{{ ai_gen_id }}
  class="ai-image-gallery-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-gallery__container-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign image = block.settings[image_key]
      %}

      {% if image != blank %}
        <div class="ai-image-gallery__item-{{ ai_gen_id }}">
          <div class="ai-image-gallery__image-wrapper-{{ ai_gen_id }}">
            <img
              src="{{ image | image_url: width: 800 }}"
              srcset="{{ image | image_url: width: 400 }} 400w,
                      {{ image | image_url: width: 600 }} 600w,
                      {{ image | image_url: width: 800 }} 800w,
                      {{ image | image_url: width: 1000 }} 1000w"
              sizes="(min-width: 750px) calc({{ block.settings.desktop_width_percent }}% / {{ block.settings.columns_desktop }}), calc(100vw / {{ block.settings.columns_mobile }})"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-image-gallery__image-{{ ai_gen_id }}"
            >
          </div>
        </div>
      {% elsif i <= 7 %}
        <div class="ai-image-gallery__item-{{ ai_gen_id }}">
          <div class="ai-image-gallery__image-wrapper-{{ ai_gen_id }}">
            <div class="ai-image-gallery__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</image-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupLazyLoading();
      }

      setupLazyLoading() {
        const images = this.querySelectorAll('.ai-image-gallery__image-{{ ai_gen_id }}');
        
        if ('IntersectionObserver' in window) {
          const imageObserver = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                const img = entry.target;
                img.classList.add('loaded');
                observer.unobserve(img);
              }
            });
          });

          images.forEach(img => imageObserver.observe(img));
        }
      }
    }

    customElements.define('image-gallery-{{ ai_gen_id }}', ImageGallery{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image gallery",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between images",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap on mobile",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Image style"
    },
    {
      "type": "range",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "min": 50,
      "max": 150,
      "step": 5,
      "unit": "%",
      "default": 100,
      "info": "100% = square, 75% = landscape, 133% = portrait"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "enable_hover_zoom",
      "label": "Enable hover zoom",
      "default": true
    },
    {
      "type": "color",
      "id": "placeholder_bg_color",
      "label": "Placeholder background",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Image 5"
    },
    {
      "type": "image_picker",
      "id": "image_6",
      "label": "Image 6"
    },
    {
      "type": "image_picker",
      "id": "image_7",
      "label": "Image 7"
    },
    {
      "type": "image_picker",
      "id": "image_8",
      "label": "Image 8"
    },
    {
      "type": "image_picker",
      "id": "image_9",
      "label": "Image 9"
    },
    {
      "type": "image_picker",
      "id": "image_10",
      "label": "Image 10"
    }
  ],
  "presets": [
    {
      "name": "Image gallery"
    }
  ]
}
{% endschema %}
