{% doc %}
  @prompt
    create this type of exact section with option to add atleast 7 image but can be upto 10 images, i want to create exact section as attached with the centere title , "what's Included in the box?" in bolder and everyting in single row , with beautiful cornerd  images
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-whats-included-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-whats-included__title-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0 0 {{ block.settings.title_spacing }}px;
    color: {{ block.settings.title_color }};
  }

  .ai-whats-included__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.items_per_row }}, 1fr);
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-whats-included__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ai-whats-included__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.placeholder_bg_color }};
    margin-bottom: {{ block.settings.label_spacing }}px;
  }

  .ai-whats-included__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-whats-included__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-whats-included__placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-whats-included__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: {{ block.settings.label_weight }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-whats-included__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.items_per_row_mobile }}, 1fr);
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-whats-included__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.75 }}px;
      margin-bottom: {{ block.settings.title_spacing | times: 0.75 }}px;
    }
  }
{% endstyle %}

<whats-included-{{ ai_gen_id }}
  class="ai-whats-included-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.title != blank %}
    <h2 class="ai-whats-included__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  {% endif %}

  <div class="ai-whats-included__grid-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign label_key = 'label_' | append: i
        assign image = block.settings[image_key]
        assign label = block.settings[label_key]
      %}

      {% if image != blank or label != blank %}
        <div class="ai-whats-included__item-{{ ai_gen_id }}">
          <div class="ai-whats-included__image-wrapper-{{ ai_gen_id }}">
            {% if image != blank %}
              <img
                src="{{ image | image_url: width: 600 }}"
                srcset="{{ image | image_url: width: 300 }} 300w,
                        {{ image | image_url: width: 400 }} 400w,
                        {{ image | image_url: width: 600 }} 600w"
                sizes="(min-width: 750px) calc({{ block.settings.desktop_width_percent }}% / {{ block.settings.items_per_row }}), calc(100vw / {{ block.settings.items_per_row_mobile }})"
                alt="{{ label | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-whats-included__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-whats-included__placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          {% if label != blank %}
            <p class="ai-whats-included__label-{{ ai_gen_id }}">{{ label }}</p>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</whats-included-{{ ai_gen_id }}>

<script>
  (function() {
    class WhatsIncluded{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupObserver();
      }

      setupObserver() {
        const images = this.querySelectorAll('.ai-whats-included__image-{{ ai_gen_id }}');
        
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
              }
            });
          }, { threshold: 0.1 });

          images.forEach(img => {
            img.style.opacity = '0';
            img.style.transition = 'opacity 0.3s ease';
            observer.observe(img);
          });
        }
      }
    }

    customElements.define('whats-included-{{ ai_gen_id }}', WhatsIncluded{{ ai_gen_id }});
  })();
</script>

