{% doc %}
  @prompt
    Create a high-end, modern, visually stunning testimonial section
    Design a premium, trust-building testimonial section that feels like a luxury brand (similar to Apple / Glossier / high-end beauty brands).
    
    Layout Requirements:
    🖥 Desktop:
    Centered section with max-width container
    Heading at top
    Below: Testimonial cards in a slider or grid
    Optional: 3 cards visible at once
    📱 Mobile:
    Horizontal scroll / swipe slider
    One card per view
    ✨ Content Structure:
    🔝 Heading:
    Main: Loved by Our Customers
    Subtext: Real stories. Real results.
    💬 Testimonial Card (Repeatable Block):
    
    Each card must include:
    
    ⭐ Star rating (5 stars)
    🗣 Testimonial text (2–4 lines)
    👤 Customer name
    🏙 Optional: Location or role
    🖼 Customer image (optional avatar)
    ✔ Optional: “Verified Buyer” badge
    🎨 Design Style:
    Ultra-modern, minimal, clean UI
    Soft shadows + glassmorphism (optional)
    Rounded corners (border-radius: 16px–24px)
    Smooth hover animations
    🎨 Color Palette:
    Primary: #E06285
    Secondary: #A08CCB
    Background: white / very light gradient
    Accent: subtle gold highlights
    💎 Visual Enhancements:
    Subtle card hover lift effect
    Gradient borders or glow effect
    Star icons in gold or primary color
    Quote icon in background (faded)
    🎞 Optional Animations:
    Fade-in on scroll
    Auto-slide testimonials
    Smooth transitions
    
    
    
    everything from color to height width must be customizable 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-testimonials-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-testimonials-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subtext_spacing }}px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .ai-testimonials-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0;
    opacity: 0.8;
  }

  .ai-testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.cards_per_row }}, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin-bottom: 20px;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    height: {{ block.settings.card_height }}px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  {% if block.settings.enable_gradient_border %}
    .ai-testimonial-card-{{ ai_gen_id }}::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      border-radius: {{ block.settings.card_border_radius }}px;
      padding: {{ block.settings.gradient_border_width }}px;
      background: linear-gradient(135deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      opacity: {{ block.settings.gradient_border_opacity | divided_by: 100.0 }};
    }
  {% endif %}

  {% if block.settings.enable_hover_effect %}
    .ai-testimonial-card-{{ ai_gen_id }}:hover {
      transform: translateY(-{{ block.settings.hover_lift }}px);
      box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y | plus: 10 }}px {{ block.settings.card_shadow_blur | plus: 10 }}px {{ block.settings.card_shadow_color }};
    }
  {% endif %}

  .ai-testimonial-quote-icon-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.card_padding }}px;
    right: {{ block.settings.card_padding }}px;
    width: {{ block.settings.quote_icon_size }}px;
    height: {{ block.settings.quote_icon_size }}px;
    opacity: {{ block.settings.quote_icon_opacity | divided_by: 100.0 }};
    color: {{ block.settings.quote_icon_color }};
  }

  .ai-testimonial-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: {{ block.settings.stars_spacing }}px;
  }

  .ai-testimonial-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    color: {{ block.settings.star_color }};
  }

  .ai-testimonial-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.testimonial_text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.testimonial_text_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
    flex-grow: 1;
  }

  .ai-testimonial-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.author_gap }}px;
  }

  .ai-testimonial-avatar-{{ ai_gen_id }} {
    width: {{ block.settings.avatar_size }}px;
    height: {{ block.settings.avatar_size }}px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid {{ block.settings.avatar_border_color }};
  }

  .ai-testimonial-avatar-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.avatar_size }}px;
    height: {{ block.settings.avatar_size }}px;
    border-radius: 50%;
    background: {{ block.settings.avatar_placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.avatar_size | divided_by: 2 }}px;
    font-weight: 600;
    color: {{ block.settings.avatar_placeholder_color }};
    border: 2px solid {{ block.settings.avatar_border_color }};
  }

  .ai-testimonial-author-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-testimonial-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_size }}px;
    font-weight: 600;
    color: {{ block.settings.name_color }};
    margin: 0 0 4px;
  }

  .ai-testimonial-location-{{ ai_gen_id }} {
    font-size: {{ block.settings.location_size }}px;
    color: {{ block.settings.location_color }};
    margin: 0;
    opacity: 0.7;
  }

  .ai-testimonial-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    border-radius: 12px;
    font-size: {{ block.settings.badge_text_size }}px;
    font-weight: 500;
  }

  .ai-testimonial-badge-icon-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
  }

  @media screen and (max-width: 989px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.cards_per_row_tablet }}, 1fr);
    }

    .ai-testimonials-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-testimonial-card-{{ ai_gen_id }} {
      height: auto;
      min-height: {{ block.settings.card_height | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 16px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-testimonials-grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: {{ block.settings.card_gap | times: 0.8 }}px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 10px;
    }

    .ai-testimonials-grid-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-testimonial-card-{{ ai_gen_id }} {
      min-width: 85%;
      scroll-snap-align: center;
      height: auto;
      min-height: {{ block.settings.card_height | times: 0.7 }}px;
    }

    .ai-testimonials-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-testimonial-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.testimonial_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<testimonials-section-{{ ai_gen_id }} class="ai-testimonials-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonials-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subtext != blank %}
      <div class="ai-testimonials-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-testimonials-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subtext != blank %}
          <p class="ai-testimonials-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-testimonials-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign testimonial_enabled_key = 'testimonial_' | append: i | append: '_enabled'
          assign testimonial_text_key = 'testimonial_' | append: i | append: '_text'
          assign testimonial_name_key = 'testimonial_' | append: i | append: '_name'
          assign testimonial_location_key = 'testimonial_' | append: i | append: '_location'
          assign testimonial_image_key = 'testimonial_' | append: i | append: '_image'
          assign testimonial_verified_key = 'testimonial_' | append: i | append: '_verified'
          assign testimonial_rating_key = 'testimonial_' | append: i | append: '_rating'

          assign testimonial_enabled = block.settings[testimonial_enabled_key]
          assign testimonial_text = block.settings[testimonial_text_key]
          assign testimonial_name = block.settings[testimonial_name_key]
          assign testimonial_location = block.settings[testimonial_location_key]
          assign testimonial_image = block.settings[testimonial_image_key]
          assign testimonial_verified = block.settings[testimonial_verified_key]
          assign testimonial_rating = block.settings[testimonial_rating_key]
        %}

        {% if testimonial_enabled %}
          <div class="ai-testimonial-card-{{ ai_gen_id }}">
            {% if block.settings.show_quote_icon %}
              <svg class="ai-testimonial-quote-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor">
                <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
              </svg>
            {% endif %}

            <div>
              <div class="ai-testimonial-stars-{{ ai_gen_id }}">
                {% for star in (1..testimonial_rating) %}
                  <svg class="ai-testimonial-star-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {% endfor %}
              </div>

              {% if testimonial_text != blank %}
                <p class="ai-testimonial-text-{{ ai_gen_id }}">{{ testimonial_text }}</p>
              {% endif %}
            </div>

            <div class="ai-testimonial-author-{{ ai_gen_id }}">
              {% if testimonial_image != blank %}
                <img 
                  src="{{ testimonial_image | image_url: width: 100 }}" 
                  alt="{{ testimonial_name }}"
                  class="ai-testimonial-avatar-{{ ai_gen_id }}"
                  loading="lazy"
                  width="100"
                  height="100"
                >
              {% else %}
                <div class="ai-testimonial-avatar-placeholder-{{ ai_gen_id }}">
                  {% if testimonial_name != blank %}
                    {{ testimonial_name | slice: 0 | upcase }}
                  {% else %}
                    ?
                  {% endif %}
                </div>
              {% endif %}

              <div class="ai-testimonial-author-info-{{ ai_gen_id }}">
                {% if testimonial_name != blank %}
                  <div class="ai-testimonial-name-{{ ai_gen_id }}">{{ testimonial_name }}</div>
                {% endif %}
                {% if testimonial_location != blank %}
                  <div class="ai-testimonial-location-{{ ai_gen_id }}">{{ testimonial_location }}</div>
                {% endif %}
              </div>

              {% if testimonial_verified and block.settings.show_verified_badge %}
                <div class="ai-testimonial-badge-{{ ai_gen_id }}">
                  <svg class="ai-testimonial-badge-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                  </svg>
                  Verified
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</testimonials-section-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialsSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupMobileScroll();
      }

      setupMobileScroll() {
        const grid = this.querySelector('.ai-testimonials-grid-{{ ai_gen_id }}');
        if (!grid) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        grid.addEventListener('mousedown', (e) => {
          if (window.innerWidth > 749) return;
          isDown = true;
          startX = e.pageX - grid.offsetLeft;
          scrollLeft = grid.scrollLeft;
        });

        grid.addEventListener('mouseleave', () => {
          isDown = false;
        });

        grid.addEventListener('mouseup', () => {
          isDown = false;
        });

        grid.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          if (window.innerWidth > 749) return;
          e.preventDefault();
          const x = e.pageX - grid.offsetLeft;
          const walk = (x - startX) * 2;
          grid.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('testimonials-section-{{ ai_gen_id }}', TestimonialsSection{{ ai_gen_id }});
  })();
</script>

