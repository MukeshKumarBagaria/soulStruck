{% doc %}
  @prompt
    Create a “Bestsellers” product section for my Shopify store.
    
    Requirements:
    - Add a heading (e.g. “Bestsellers” with a subheading option).
    - Allow me to select a collection (default: Best Sellers collection).
    - Display products in a grid layout (desktop: 4 per row, mobile: 2 per row).
    - Show at least 8 products by default, but allow me to customize the number of products to display.
    - Each product card should include:
      - Product image
      - Product title
      - Price (with compare-at price if available)
      - Optional badge (e.g. “Hot Seller” or “Save ₹X”)
      - Add to Cart button
    
    Customization options:
    - Option to change number of products shown
    - Option to change collection
    - Toggle for showing badges, ratings, and offers
    - Option to edit heading and subheading text
    
    Extra feature:
    - Add a “View All” button below the section that links to the selected collection page.
    
    Design:
    - Clean, modern, minimal UI
    - Rounded product cards with soft shadows
    - Mobile responsive
    
    Goal:
    Make it visually appealing and optimized for conversions.
    
    
    create same as attached  section   , it must be fully dynamic fully mobile responsive 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bestsellers-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-bestsellers-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-bestsellers-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-bestsellers-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 700;
  }

  .ai-bestsellers-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-bestsellers-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 40px;
  }

  .ai-bestsellers-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
  }

  .ai-bestsellers-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical | plus: 4 }}px {{ block.settings.card_shadow_blur | plus: 8 }}px {{ block.settings.card_shadow_color }};
  }

  .ai-bestsellers-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-bestsellers-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-bestsellers-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    right: 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: 12px;
    font-weight: 600;
    z-index: 2;
  }

  .ai-bestsellers-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-bestsellers-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 8px;
    font-weight: 600;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-bestsellers-title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-bestsellers-title-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.heading_color }};
  }

  .ai-bestsellers-price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ai-bestsellers-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 700;
  }

  .ai-bestsellers-compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size | minus: 2 }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    opacity: 0.7;
  }

  .ai-bestsellers-savings-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.badge_background }};
    font-weight: 600;
  }

  .ai-bestsellers-add-to-cart-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-bestsellers-add-to-cart-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-bestsellers-view-all-wrapper-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-bestsellers-view-all-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.view_all_background }};
    color: {{ block.settings.view_all_text_color }};
    border: 2px solid {{ block.settings.view_all_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .ai-bestsellers-view-all-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.view_all_hover_background }};
    color: {{ block.settings.view_all_hover_text_color }};
    border-color: {{ block.settings.view_all_hover_border_color }};
  }

  .ai-bestsellers-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
  }

  .ai-bestsellers-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 989px) {
    .ai-bestsellers-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.8 }}px;
    }

    .ai-bestsellers-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-bestsellers-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-bestsellers-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 16px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-bestsellers-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.6 }}px;
    }

    .ai-bestsellers-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-bestsellers-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-bestsellers-card-content-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.7 }}px;
    }

    .ai-bestsellers-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.product_title_size | times: 0.85 }}px;
    }

    .ai-bestsellers-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size | times: 0.9 }}px;
    }

    .ai-bestsellers-add-to-cart-{{ ai_gen_id }} {
      padding: 10px 16px;
      font-size: 13px;
    }

    .ai-bestsellers-badge-{{ ai_gen_id }} {
      font-size: 10px;
      padding: 4px 8px;
    }
  }
{% endstyle %}

<bestsellers-section-{{ ai_gen_id }} class="ai-bestsellers-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bestsellers-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-bestsellers-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-bestsellers-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-bestsellers-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      <div class="ai-bestsellers-grid-{{ ai_gen_id }}">
        {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
          <div class="ai-bestsellers-card-{{ ai_gen_id }}">
            <div class="ai-bestsellers-image-wrapper-{{ ai_gen_id }}">
              <a href="{{ product.url }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-bestsellers-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% else %}
                  <div class="ai-bestsellers-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </a>

              {% if block.settings.show_badges %}
                {% if product.compare_at_price > product.price %}
                  {% assign savings = product.compare_at_price | minus: product.price %}
                  <div class="ai-bestsellers-badge-{{ ai_gen_id }}">
                    {% if block.settings.badge_type == 'percentage' %}
                      {% assign savings_percent = savings | times: 100 | divided_by: product.compare_at_price %}
                      {{ savings_percent }}% OFF
                    {% elsif block.settings.badge_type == 'amount' %}
                      Save {{ savings | money }}
                    {% else %}
                      {{ block.settings.custom_badge_text }}
                    {% endif %}
                  </div>
                {% elsif block.settings.show_custom_badge and block.settings.custom_badge_text != blank %}
                  <div class="ai-bestsellers-badge-{{ ai_gen_id }}">
                    {{ block.settings.custom_badge_text }}
                  </div>
                {% endif %}
              {% endif %}
            </div>

            <div class="ai-bestsellers-card-content-{{ ai_gen_id }}">
              <h3 class="ai-bestsellers-title-{{ ai_gen_id }}">
                <a href="{{ product.url }}" class="ai-bestsellers-title-link-{{ ai_gen_id }}">
                  {{ product.title }}
                </a>
              </h3>

              <div class="ai-bestsellers-price-wrapper-{{ ai_gen_id }}">
                <span class="ai-bestsellers-price-{{ ai_gen_id }}">
                  {{ product.price | money }}
                </span>
                {% if product.compare_at_price > product.price %}
                  <span class="ai-bestsellers-compare-price-{{ ai_gen_id }}">
                    {{ product.compare_at_price | money }}
                  </span>
                  {% if block.settings.show_savings %}
                    {% assign savings = product.compare_at_price | minus: product.price %}
                    <span class="ai-bestsellers-savings-{{ ai_gen_id }}">
                      Save {{ savings | money }}
                    </span>
                  {% endif %}
                {% endif %}
              </div>

              {% if block.settings.show_add_to_cart %}
                <button
                  class="ai-bestsellers-add-to-cart-{{ ai_gen_id }}"
                  data-product-id="{{ product.id }}"
                  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                  {% unless product.available %}disabled{% endunless %}
                >
                  {% if product.available %}
                    {{ block.settings.add_to_cart_text }}
                  {% else %}
                    Sold Out
                  {% endif %}
                </button>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      {% if block.settings.show_view_all %}
        <div class="ai-bestsellers-view-all-wrapper-{{ ai_gen_id }}">
          <a href="{{ block.settings.collection.url }}" class="ai-bestsellers-view-all-{{ ai_gen_id }}">
            {{ block.settings.view_all_text }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-bestsellers-grid-{{ ai_gen_id }}">
        {% for i in (1..8) %}
          <div class="ai-bestsellers-card-{{ ai_gen_id }}">
            <div class="ai-bestsellers-image-wrapper-{{ ai_gen_id }}">
              <div class="ai-bestsellers-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            </div>
            <div class="ai-bestsellers-card-content-{{ ai_gen_id }}">
              <h3 class="ai-bestsellers-title-{{ ai_gen_id }}">Product Title</h3>
              <div class="ai-bestsellers-price-wrapper-{{ ai_gen_id }}">
                <span class="ai-bestsellers-price-{{ ai_gen_id }}">₹999</span>
              </div>
              {% if block.settings.show_add_to_cart %}
                <button class="ai-bestsellers-add-to-cart-{{ ai_gen_id }}" disabled>
                  {{ block.settings.add_to_cart_text }}
                </button>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</bestsellers-section-{{ ai_gen_id }}>

<script>
  (function() {
    class BestsellersSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAddToCart();
      }

      setupAddToCart() {
        const buttons = this.querySelectorAll('.ai-bestsellers-add-to-cart-{{ ai_gen_id }}');
        
        buttons.forEach(button => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            const variantId = button.dataset.variantId;
            
            if (!variantId) return;

            button.textContent = 'Adding...';
            button.disabled = true;

            fetch('/cart/add.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                id: variantId,
                quantity: 1
              })
            })
            .then(response => response.json())
            .then(data => {
              button.textContent = 'Added!';
              
              setTimeout(() => {
                button.textContent = '{{ block.settings.add_to_cart_text }}';
                button.disabled = false;
              }, 2000);

              if (window.theme && window.theme.cart) {
                window.theme.cart.refresh();
              }

              document.dispatchEvent(new CustomEvent('cart:refresh'));
            })
            .catch(error => {
              console.error('Error:', error);
              button.textContent = 'Error';
              setTimeout(() => {
                button.textContent = '{{ block.settings.add_to_cart_text }}';
                button.disabled = false;
              }, 2000);
            });
          });
        });
      }
    }

    customElements.define('bestsellers-section-{{ ai_gen_id }}', BestsellersSection{{ ai_gen_id }});
  })();
</script>

