{% doc %}
  @prompt
    Create a modern full-width slider section with a split layout (image on left, text on right).
    
    Layout:
    - Two-column layout (50% image, 50% content)
    - Left side: large image (model/product lifestyle image)
    - Right side: text content aligned vertically center
    - Full-width section with clean spacing
    
    Slider Functionality:
    - Allow multiple slides (at least 3–5)
    - Smooth sliding transition (fade or slide)
    - Optional autoplay with speed control
    - Navigation arrows and dots
    
    Content per Slide:
    - Image (upload option)
    - Heading (e.g. “Made to last”)
    - Description (short paragraph)
    - Optional CTA button (e.g. “Shop Now”)
    
    Customization Options:
    - Image position toggle (left/right)
    - Text alignment (left, center)
    - Background color for text section
    - Overlay option for image (light/dark)
    - Padding and spacing controls
    - Font size and typography control
    - Enable/disable autoplay
    - Slider speed control
    - Mobile responsive stacking (image on top, text below)
    
    Design Style:
    - Minimal, premium look
    - Large bold heading
    - Soft muted text color for description
    - Smooth animations (fade-in text)
    
    Goal:
    Create a high-end, visually appealing storytelling slider that highlights product benefits.
    , provide an option to choose the font type also 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-split-slider__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-split-slider__slide-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    opacity: 0;
    transition: opacity 0.6s ease-in-out;
  }

  .ai-split-slider__slide-{{ ai_gen_id }}.active {
    display: flex;
    opacity: 1;
  }

  .ai-split-slider__content-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    min-height: {{ block.settings.section_height }}px;
    {% if block.settings.image_position == 'right' %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-split-slider__image-container-{{ ai_gen_id }} {
    width: 50%;
    position: relative;
    overflow: hidden;
  }

  .ai-split-slider__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-split-slider__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-split-slider__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-split-slider__image-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    {% if block.settings.image_overlay == 'light' %}
      background-color: rgba(255, 255, 255, {{ block.settings.overlay_opacity }});
    {% elsif block.settings.image_overlay == 'dark' %}
      background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    {% endif %}
  }

  .ai-split-slider__text-container-{{ ai_gen_id }} {
    width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: {% if block.settings.text_alignment == 'center' %}center{% else %}flex-start{% endif %};
    padding: {{ block.settings.text_padding }}px;
    background-color: {{ block.settings.text_background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-split-slider__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.content_spacing }}px 0;
    line-height: 1.2;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease-out 0.2s, transform 0.8s ease-out 0.2s;
  }

  .ai-split-slider__slide-{{ ai_gen_id }}.active .ai-split-slider__heading-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-split-slider__description-{{ ai_gen_id }} {
    font-family: {{ block.settings.description_font.family }}, {{ block.settings.description_font.fallback_families }};
    font-weight: {{ block.settings.description_font.weight }};
    font-style: {{ block.settings.description_font.style }};
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 {{ block.settings.content_spacing }}px 0;
    line-height: 1.6;
    max-width: 500px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease-out 0.4s, transform 0.8s ease-out 0.4s;
  }

  .ai-split-slider__slide-{{ ai_gen_id }}.active .ai-split-slider__description-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-split-slider__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-style: {{ block.settings.button_font.style }};
    font-size: {{ block.settings.button_font_size }}px;
    transition: background-color 0.3s ease, transform 0.3s ease;
    opacity: 0;
    transform: translateY(20px);
    border: none;
    cursor: pointer;
  }

  .ai-split-slider__slide-{{ ai_gen_id }}.active .ai-split-slider__button-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s ease-out 0.6s, transform 0.8s ease-out 0.6s, background-color 0.3s ease;
  }

  .ai-split-slider__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
  }

  .ai-split-slider__controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.controls_bottom_spacing }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 10;
  }

  .ai-split-slider__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.4;
    cursor: pointer;
    transition: opacity 0.3s ease, transform 0.3s ease;
    border: none;
    padding: 0;
  }

  .ai-split-slider__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  .ai-split-slider__arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: background-color 0.3s ease, transform 0.3s ease;
    opacity: 0.8;
  }

  .ai-split-slider__arrow-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: translateY(-50%) scale(1.1);
  }

  .ai-split-slider__arrow-{{ ai_gen_id }}--prev {
    left: 20px;
  }

  .ai-split-slider__arrow-{{ ai_gen_id }}--next {
    right: 20px;
  }

  .ai-split-slider__arrow-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-split-slider__content-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      min-height: auto;
    }

    .ai-split-slider__image-container-{{ ai_gen_id }},
    .ai-split-slider__text-container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-split-slider__image-container-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-split-slider__text-container-{{ ai_gen_id }} {
      padding: {{ block.settings.text_padding | times: 0.6 }}px;
    }

    .ai-split-slider__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-split-slider__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-split-slider__arrow-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-split-slider__arrow-{{ ai_gen_id }}--prev {
      left: 10px;
    }

    .ai-split-slider__arrow-{{ ai_gen_id }}--next {
      right: 10px;
    }
  }
{% endstyle %}

<split-slider-{{ ai_gen_id }} class="ai-split-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-split-slider__wrapper-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
        assign slide_image_key = 'slide_' | append: i | append: '_image'
        assign slide_heading_key = 'slide_' | append: i | append: '_heading'
        assign slide_description_key = 'slide_' | append: i | append: '_description'
        assign slide_button_text_key = 'slide_' | append: i | append: '_button_text'
        assign slide_button_link_key = 'slide_' | append: i | append: '_button_link'

        assign slide_enabled = block.settings[slide_enabled_key]
        assign slide_image = block.settings[slide_image_key]
        assign slide_heading = block.settings[slide_heading_key]
        assign slide_description = block.settings[slide_description_key]
        assign slide_button_text = block.settings[slide_button_text_key]
        assign slide_button_link = block.settings[slide_button_link_key]
      %}

      {% if slide_enabled %}
        <div class="ai-split-slider__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide="{{ i }}">
          <div class="ai-split-slider__content-wrapper-{{ ai_gen_id }}">
            <div class="ai-split-slider__image-container-{{ ai_gen_id }}">
              {% if slide_image %}
                <img
                  src="{{ slide_image | image_url: width: 2000 }}"
                  alt="{{ slide_image.alt | escape }}"
                  class="ai-split-slider__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ slide_image.width }}"
                  height="{{ slide_image.height }}"
                >
              {% else %}
                <div class="ai-split-slider__image-placeholder-{{ ai_gen_id }}">
                  {{ 'lifestyle-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
              {% if block.settings.image_overlay != 'none' %}
                <div class="ai-split-slider__image-overlay-{{ ai_gen_id }}"></div>
              {% endif %}
            </div>

            <div class="ai-split-slider__text-container-{{ ai_gen_id }}">
              {% if slide_heading != blank %}
                <h2 class="ai-split-slider__heading-{{ ai_gen_id }}">{{ slide_heading }}</h2>
              {% endif %}

              {% if slide_description != blank %}
                <p class="ai-split-slider__description-{{ ai_gen_id }}">{{ slide_description }}</p>
              {% endif %}

              {% if slide_button_text != blank %}
                <a
                  href="{{ slide_button_link | default: '#' }}"
                  class="ai-split-slider__button-{{ ai_gen_id }}"
                >
                  {{ slide_button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}

    {% if block.settings.show_arrows %}
      <button class="ai-split-slider__arrow-{{ ai_gen_id }} ai-split-slider__arrow-{{ ai_gen_id }}--prev" aria-label="Previous slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="ai-split-slider__arrow-{{ ai_gen_id }} ai-split-slider__arrow-{{ ai_gen_id }}--next" aria-label="Next slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-split-slider__controls-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
            assign slide_enabled = block.settings[slide_enabled_key]
          %}
          {% if slide_enabled %}
            <button
              class="ai-split-slider__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              data-slide="{{ i }}"
              aria-label="Go to slide {{ i }}"
            ></button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</split-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class SplitSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-split-slider__slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-split-slider__dot-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('.ai-split-slider__arrow-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-split-slider__arrow-{{ ai_gen_id }}--next');

        this.setupEventListeners();
        
        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          {% if block.settings.autoplay %}
            this.startAutoplay();
          {% endif %}
        });
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        this.dots[this.currentSlide].classList.remove('active');

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        this.dots[this.currentSlide].classList.add('active');
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('split-slider-{{ ai_gen_id }}', SplitSlider{{ ai_gen_id }});
  })();
</script>

