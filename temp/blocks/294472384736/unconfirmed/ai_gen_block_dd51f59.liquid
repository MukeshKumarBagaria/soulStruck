      "label": "Post 1 URL"
    },
    {
      "type": "image_picker",
      "id": "post_2_image",
      "label": "Post 2 image"
    },
    {
      "type": "url",
      "id": "post_2_url",
      "label": "Post 2 URL"
    },
    {
      "type": "image_picker",
      "id": "post_3_image",
      "label": "Post 3 image"
    },
    {
      "type": "url",
      "id": "post_3_url",
      "label": "Post 3 URL"
    },
    {
      "type": "image_picker",
      "id": "post_4_image",
      "label": "Post 4 image"
    },
