      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "profile_spacing",
      "label": "Spacing below profile",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Follow button"
    },
    {
      "type": "checkbox",
      "id": "show_follow_button",
