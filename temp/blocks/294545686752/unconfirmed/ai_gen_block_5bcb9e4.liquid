{% doc %}
  @prompt
    Create a modern “Social Proof Slider” section for my Shopify store with infinite horizontal scrolling animation.
    
    Title (IMPORTANT):
    - Set the default heading as:
      “🫶 Loved by favourites & 20,000+ more just like you”
    - Allow editing of this title from settings
    
    Layout:
    - Full-width section
    - Title centered at the top
    - Below the title, display a horizontal scrolling slider of image cards
    
    Slider Functionality:
    - Infinite horizontal scrolling (loop animation)
    - Auto-scroll continuously (marquee style)
    - Smooth linear animation (no jerks)
    - Pause animation on hover (desktop)
    - Touch swipe enabled on mobile
    - Seamless looping (duplicate items internally to avoid gaps)
    
    Image Cards:
    - All image cards must have consistent height (IMPORTANT)
    - Maintain uniform aspect ratio (portrait preferred, e.g. 4:5)
    - Rounded corners (medium radius)
    - Equal spacing between cards
    - Images should cover fully (object-fit: cover)
    
    Customization Options:
    - Upload multiple images (UGC / Instagram-style content)
    - Control:
      - Animation speed (slow / medium / fast + custom range)
      - Card height
      - Gap between cards
      - Border radius
    - Toggle:
      - Pause on hover
      - Enable/disable autoplay
    - Option to duplicate rows (single row / double row slider)
    
    Design:
    - Clean, minimal, premium
    - Focus on real user content (UGC style)
    - Optional subtle hover effect (scale slightly)
    
    Mobile Optimization:
    - Fully responsive
    - Smooth touch scrolling
    - Maintain consistent card size
    - No layout shift
    
    Performance:
    - Lazy load images
    - Optimize for smooth animation (use CSS transform, not heavy JS)
    
    Optional Enhancements:
    - Slight fade gradient on left/right edges for premium look
    - Subtle entrance animation on section load
    
    Goal:
    Create a high-converting, visually engaging infinite scrolling slider that builds trust using real user content and feels smooth and premium like top D2C brands., provide option to add upto 30 photos , just add one feature also that even though there can be upto 30 images but it's not necssary that there will be thirty ,for each image given an toggle button to enable disable that 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-social-proof-slider-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    position: relative;
    display: block;
  }

  .ai-social-proof-slider__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 auto {{ block.settings.heading_margin_bottom }}px;
    padding: 0 20px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    max-width: 800px;
  }

  .ai-social-proof-slider__track-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  {% if block.settings.show_fade_edges %}
    .ai-social-proof-slider__track-wrapper-{{ ai_gen_id }}::before,
    .ai-social-proof-slider__track-wrapper-{{ ai_gen_id }}::after {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      width: {{ block.settings.fade_width }}px;
      z-index: 2;
      pointer-events: none;
    }

    .ai-social-proof-slider__track-wrapper-{{ ai_gen_id }}::before {
      left: 0;
      background: linear-gradient(to right, {{ block.settings.background_color }}, transparent);
    }

    .ai-social-proof-slider__track-wrapper-{{ ai_gen_id }}::after {
      right: 0;
      background: linear-gradient(to left, {{ block.settings.background_color }}, transparent);
    }
  {% endif %}

  .ai-social-proof-slider__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    width: fit-content;
    {% if block.settings.enable_autoplay %}
      animation: ai-social-proof-scroll-{{ ai_gen_id }} {{ block.settings.animation_duration }}s linear infinite;
    {% endif %}
  }

  {% if block.settings.pause_on_hover %}
    .ai-social-proof-slider__track-{{ ai_gen_id }}:hover {
      animation-play-state: paused;
    }
  {% endif %}

  .ai-social-proof-slider__card-{{ ai_gen_id }} {
    flex-shrink: 0;
    height: {{ block.settings.card_height }}px;
    width: auto;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    position: relative;
    {% if block.settings.enable_hover_effect %}
      transition: transform 0.3s ease;
    {% endif %}
  }

  {% if block.settings.enable_hover_effect %}
    .ai-social-proof-slider__card-{{ ai_gen_id }}:hover {
      transform: scale(1.05);
    }
  {% endif %}

  .ai-social-proof-slider__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-social-proof-slider__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-social-proof-slider__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @keyframes ai-social-proof-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - {{ block.settings.card_gap | divided_by: 2.0 }}px));
    }
  }

  {% if block.settings.show_entrance_animation %}
    .ai-social-proof-slider-{{ ai_gen_id }} {
      opacity: 0;
      transform: translateY(20px);
      animation: ai-social-proof-entrance-{{ ai_gen_id }} 0.8s ease forwards;
    }

    @keyframes ai-social-proof-entrance-{{ ai_gen_id }} {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-social-proof-slider__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
      margin-bottom: {{ block.settings.heading_margin_bottom | times: 0.7 }}px;
    }

    .ai-social-proof-slider__card-{{ ai_gen_id }} {
      height: {{ block.settings.card_height | times: 0.8 }}px;
    }

    .ai-social-proof-slider-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 0 {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }
  }
{% endstyle %}

<social-proof-slider-{{ ai_gen_id }}
  class="ai-social-proof-slider-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-autoplay="{{ block.settings.enable_autoplay }}"
  data-pause-on-hover="{{ block.settings.pause_on_hover }}"
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-social-proof-slider__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h2>
  {% endif %}

  <div class="ai-social-proof-slider__track-wrapper-{{ ai_gen_id }}">
    <div class="ai-social-proof-slider__track-{{ ai_gen_id }}">
      {% liquid
        assign total_images = 0
        for i in (1..30)
          assign image_key = 'image_' | append: i
          assign enable_key = 'enable_image_' | append: i
          assign current_image = block.settings[image_key]
          assign is_enabled = block.settings[enable_key]
          if current_image != blank and is_enabled
            assign total_images = total_images | plus: 1
          endif
        endfor
      %}

      {% if total_images > 0 %}
        {% for iteration in (1..2) %}
          {% for i in (1..30) %}
            {% liquid
              assign image_key = 'image_' | append: i
              assign enable_key = 'enable_image_' | append: i
              assign current_image = block.settings[image_key]
              assign is_enabled = block.settings[enable_key]
            %}
            {% if current_image != blank and is_enabled %}
              <div class="ai-social-proof-slider__card-{{ ai_gen_id }}">
                {% liquid
                  assign aspect_ratio = block.settings.card_aspect_ratio
                  if aspect_ratio == '4:5'
                    assign card_width = block.settings.card_height | times: 0.8
                  elsif aspect_ratio == '3:4'
                    assign card_width = block.settings.card_height | times: 0.75
                  elsif aspect_ratio == '1:1'
                    assign card_width = block.settings.card_height
                  elsif aspect_ratio == '9:16'
                    assign card_width = block.settings.card_height | times: 0.5625
                  endif
                %}
                <img
                  src="{{ current_image | image_url: width: 800 }}"
                  alt="{{ current_image.alt | escape }}"
                  class="ai-social-proof-slider__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ card_width }}"
                  height="{{ block.settings.card_height }}"
                  style="width: {{ card_width }}px;"
                >
              </div>
            {% endif %}
          {% endfor %}
        {% endfor %}
      {% else %}
        {% for iteration in (1..2) %}
          {% for i in (1..6) %}
            <div class="ai-social-proof-slider__card-{{ ai_gen_id }}">
              {% liquid
                assign aspect_ratio = block.settings.card_aspect_ratio
                if aspect_ratio == '4:5'
                  assign card_width = block.settings.card_height | times: 0.8
                elsif aspect_ratio == '3:4'
                  assign card_width = block.settings.card_height | times: 0.75
                elsif aspect_ratio == '1:1'
                  assign card_width = block.settings.card_height
                elsif aspect_ratio == '9:16'
                  assign card_width = block.settings.card_height | times: 0.5625
                endif
              %}
              <div
                class="ai-social-proof-slider__placeholder-{{ ai_gen_id }}"
                style="width: {{ card_width }}px;"
              >
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>
          {% endfor %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</social-proof-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class SocialProofSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('.ai-social-proof-slider__track-{{ ai_gen_id }}');
        this.autoplay = this.dataset.autoplay === 'true';
        this.pauseOnHover = this.dataset.pauseOnHover === 'true';
        this.touchStartX = 0;
        this.touchEndX = 0;
        this.isDragging = false;
      }

      connectedCallback() {
        this.setupTouchEvents();
      }

      setupTouchEvents() {
        if (!this.track) return;

        this.track.addEventListener('touchstart', (e) => {
          this.touchStartX = e.changedTouches[0].screenX;
          this.isDragging = true;
        }, { passive: true });

        this.track.addEventListener('touchmove', (e) => {
          if (!this.isDragging) return;
          this.touchEndX = e.changedTouches[0].screenX;
        }, { passive: true });

        this.track.addEventListener('touchend', () => {
          this.isDragging = false;
        }, { passive: true });
      }
    }

    customElements.define('social-proof-slider-{{ ai_gen_id }}', SocialProofSlider{{ ai_gen_id }});
  })();
</script>

