{% doc %}
  @prompt
    create an block like this where there will be title , descripiton and and youtube video embeded option , provide features to create beautiful multi color title also option to set the video height width etc 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-video-block__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-video-block__title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
    font-size: {{ block.settings.title_font_size }}px;
    line-height: 1.2;
  }

  .ai-video-block__title-word-{{ ai_gen_id }} {
    display: inline-block;
  }

  .ai-video-block__title-word-{{ ai_gen_id }}--1 {
    color: {{ block.settings.title_color_1 }};
  }

  .ai-video-block__title-word-{{ ai_gen_id }}--2 {
    color: {{ block.settings.title_color_2 }};
  }

  .ai-video-block__title-word-{{ ai_gen_id }}--3 {
    color: {{ block.settings.title_color_3 }};
  }

  .ai-video-block__title-word-{{ ai_gen_id }}--4 {
    color: {{ block.settings.title_color_4 }};
  }

  .ai-video-block__title-word-{{ ai_gen_id }}--5 {
    color: {{ block.settings.title_color_5 }};
  }

  .ai-video-block__description-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.description_spacing }}px;
    color: {{ block.settings.description_color }};
    text-align: {{ block.settings.text_alignment }};
    font-size: {{ block.settings.description_font_size }}px;
  }

  .ai-video-block__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.video_width }}%;
    max-width: 100%;
    margin: 0 auto;
    overflow: hidden;
    border-radius: {{ block.settings.video_border_radius }}px;
    background-color: #f4f4f4;
  }

  {% if block.settings.video_aspect_ratio == 'custom' %}
    .ai-video-block__video-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.video_height }}px;
    }

    .ai-video-block__video-wrapper-{{ ai_gen_id }} iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
  {% else %}
    .ai-video-block__video-wrapper-{{ ai_gen_id }} {
      {% if block.settings.video_aspect_ratio == '16-9' %}
        padding-bottom: 56.25%;
      {% elsif block.settings.video_aspect_ratio == '4-3' %}
        padding-bottom: 75%;
      {% elsif block.settings.video_aspect_ratio == '1-1' %}
        padding-bottom: 100%;
      {% elsif block.settings.video_aspect_ratio == '21-9' %}
        padding-bottom: 42.86%;
      {% endif %}
    }

    .ai-video-block__video-wrapper-{{ ai_gen_id }} iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
  {% endif %}

  .ai-video-block__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-block__placeholder-message-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-block__placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-video-block-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-video-block__title-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.title_spacing | times: 0.7 }}px;
      font-size: {{ block.settings.title_font_size | times: 0.7 }}px;
    }

    .ai-video-block__description-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.description_spacing | times: 0.7 }}px;
      font-size: {{ block.settings.description_font_size | times: 0.9 }}px;
    }

    .ai-video-block__video-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    {% if block.settings.video_aspect_ratio == 'custom' %}
      .ai-video-block__video-wrapper-{{ ai_gen_id }} {
        height: {{ block.settings.video_height | times: 0.7 }}px;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-video-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-block__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-video-block__title-{{ ai_gen_id }}">
        {% assign words = block.settings.title | split: ' ' %}
        {% for word in words %}
          {% assign word_index = forloop.index | modulo: 5 %}
          {% if word_index == 0 %}
            {% assign word_index = 5 %}
          {% endif %}
          <span class="ai-video-block__title-word-{{ ai_gen_id }} ai-video-block__title-word-{{ ai_gen_id }}--{{ word_index }}">{{ word }}</span>{% unless forloop.last %} {% endunless %}
        {% endfor %}
      </h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-video-block__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}

    <div class="ai-video-block__video-wrapper-{{ ai_gen_id }}">
      {% if block.settings.youtube_url != blank %}
        {% assign video_id = block.settings.youtube_url | split: 'v=' | last | split: '&' | first %}
        {% if video_id == block.settings.youtube_url %}
          {% assign video_id = block.settings.youtube_url | split: 'youtu.be/' | last | split: '?' | first %}
        {% endif %}
        <iframe
          src="https://www.youtube.com/embed/{{ video_id }}"
          title="{{ block.settings.title | default: 'YouTube video player' | escape }}"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      {% else %}
        <div class="ai-video-block__placeholder-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
          <div class="ai-video-block__placeholder-message-{{ ai_gen_id }}">
            Next, add a YouTube video URL
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Video with text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Watch Our Amazing Video"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Learn more about our products and services in this video.</p>"
    },
    {
      "type": "text",
      "id": "youtube_url",
      "label": "YouTube URL",
      "info": "Paste the full YouTube video URL (e.g., https://www.youtube.com/watch?v=VIDEO_ID)"
    },
    {
      "type": "header",
      "content": "Title colors"
    },
    {
      "type": "paragraph",
      "content": "Each word in the title will cycle through these colors"
    },
    {
      "type": "color",
      "id": "title_color_1",
      "label": "Color 1",
      "default": "#FF6B6B"
    },
    {
      "type": "color",
      "id": "title_color_2",
      "label": "Color 2",
      "default": "#4ECDC4"
    },
    {
      "type": "color",
      "id": "title_color_3",
      "label": "Color 3",
      "default": "#FFE66D"
    },
    {
      "type": "color",
      "id": "title_color_4",
      "label": "Color 4",
      "default": "#A8E6CF"
    },
    {
      "type": "color",
      "id": "title_color_5",
      "label": "Color 5",
      "default": "#FF8B94"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title size",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "Description size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Video settings"
    },
    {
      "type": "select",
      "id": "video_aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "16-9",
          "label": "16:9 (Widescreen)"
        },
        {
          "value": "4-3",
          "label": "4:3 (Standard)"
        },
        {
          "value": "1-1",
          "label": "1:1 (Square)"
        },
        {
          "value": "21-9",
          "label": "21:9 (Ultrawide)"
        },
        {
          "value": "custom",
          "label": "Custom height"
        }
      ],
      "default": "16-9"
    },
    {
      "type": "range",
      "id": "video_height",
      "label": "Custom height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 450,
      "info": "Only applies when aspect ratio is set to Custom height"
    },
    {
      "type": "range",
      "id": "video_width",
      "label": "Video width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 900
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Title spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "description_spacing",
      "label": "Description spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Video with text"
    }
  ]
}
{% endschema %}
